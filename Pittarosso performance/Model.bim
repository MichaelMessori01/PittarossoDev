          },
          {
            "name": "Average Stock Cost R12",
            "description": "Media dello stock a costo 12 mesi rolling",
            "expression": [
              " ",
              "",
              "VAR _maxDate = ",
              "    IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP], TODAY())",
              "",
              "VAR _Last12Months =",
              "    DATESINPERIOD(",
              "        'olap vw_fact_Movements'[DataRegistrazioneMagazzino],",
              "        _maxDate,",
              "        -365,",
              "        DAY",
              "    )",
              "",
              "VAR _selectedDay = DAY(_maxDate)",
              "VAR _today = TODAY()",
              "VAR _currentYear = YEAR(_today)",
              "VAR _currentMonth = MONTH(_today)",
              "",
              "VAR _EndOfMonths =",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            ADDCOLUMNS(",
              "                _Last12Months,",
              "                \"Year\", YEAR([DataRegistrazioneMagazzino]),",
              "                \"Month\", MONTH([DataRegistrazioneMagazzino])",
              "            ),",
              "            [Year], [Month]",
              "        ),",
              "        \"EOM\",",
              "            VAR _year = [Year]",
              "            VAR _month = [Month]",
              "            VAR _daysInMonth = DAY(EOMONTH(DATE(_year, _month, 1), 0))",
              "            VAR _targetDay = ",
              "                IF(_selectedDay <= _daysInMonth, _selectedDay, _daysInMonth)",
              "            VAR _targetDate = DATE(_year, _month, _targetDay)",
              "            RETURN",
              "                CALCULATE(",
              "                    MAX('olap vw_fact_Movements'[DataRegistrazioneMagazzino]),",
              "                    'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _targetDate &&",
              "                    MONTH('olap vw_fact_Movements'[DataRegistrazioneMagazzino]) = _month &&",
              "                    YEAR('olap vw_fact_Movements'[DataRegistrazioneMagazzino]) = _year",
              "                )",
              "    )",
              "",
              "",
              "VAR _MonthlyStock =",
              "    ADDCOLUMNS(",
              "        _EndOfMonths,",
              "        \"StockCost\", ",
              "        VAR _EOM = [EOM]",
              "        RETURN",
              "        CALCULATE(",
              "            [_fx_StockCost],  ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _EOM, ",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "        )",
              "        ",
              "    )",
              "",
              "VAR _Average =",
              "    AVERAGEX(_MonthlyStock, [StockCost])",
              "",
              "RETURN",
              "    _Average"
            ],
            "displayFolder": "12 ZONING"
          },
          {
            "name": "GMROI R12",
            "description": "Rapporto tra margine e media costo di stock 12 mesi rolling",
            "expression": " DIVIDE([Sales Margin R12], [Average Stock Cost R12])",
            "formatString": "0.00",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Cog's R12",
            "description": "Costi negozi fisici 12 mesi rolling ",
            "expression": [
              " ",
              "",
              "VAR _maxDate = IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP] , TODAY())",
              "VAR _Result = ",
              "\tCALCULATE([_fx_CostoVendutoNegoziFisici], ",
              "\t\tFILTER('05 MOVEMENTS STORE ATTRIBUTES', '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _maxDate - 365 && '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= \t\t\t\t_maxDate )",
              "            \t)",
              "RETURN",
              "_Result"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Stock Turn (cost) R12",
            "description": "Rapporto tra costi negozi fisici 12 mesi rolling e media dello stock a costo 12 mesi rolling",
            "expression": " DIVIDE([Cog's R12], [Average Stock Cost R12])",
            "formatString": "0.00",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Sales qty R12",
            "description": "Quantità negozi fisici 12 mesi rolling",
            "expression": [
              " ",
              "",
              "VAR _maxDate = IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP] , TODAY())",
              "VAR _Result = ",
              "\tCALCULATE([_fx_QuantitàNegoziFisici], ",
              "\t\tFILTER('05 MOVEMENTS STORE ATTRIBUTES', '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _maxDate - 365 && '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= \t\t\t\t_maxDate )",
              "            \t)",
              "RETURN",
              "_Result"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Average Stock Qty R12",
            "description": "Media della quantità a stock 12 mesi rolling",
            "expression": [
              " ",
              "",
              "VAR _maxDate = ",
              "    IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP], TODAY())",
              "",
              "VAR _Last12Months =",
              "    DATESINPERIOD(",
              "        'olap vw_fact_Movements'[DataRegistrazioneMagazzino],",
              "        _maxDate,",
              "        -365,",
              "        DAY",
              "    )",
              "",
              "VAR _selectedDay = DAY(_maxDate)",
              "VAR _today = TODAY()",
              "VAR _currentYear = YEAR(_today)",
              "VAR _currentMonth = MONTH(_today)",
              "",
              "VAR _EndOfMonths =",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            ADDCOLUMNS(",
              "                _Last12Months,",
              "                \"Year\", YEAR([DataRegistrazioneMagazzino]),",
              "                \"Month\", MONTH([DataRegistrazioneMagazzino])",
              "            ),",
              "            [Year], [Month]",
              "        ),",
              "        \"EOM\",",
              "            VAR _year = [Year]",
              "            VAR _month = [Month]",
              "            VAR _daysInMonth = DAY(EOMONTH(DATE(_year, _month, 1), 0))",
              "            VAR _targetDay = ",
              "                IF(_selectedDay <= _daysInMonth, _selectedDay, _daysInMonth)",
              "            VAR _targetDate = DATE(_year, _month, _targetDay)",
              "            RETURN",
              "                CALCULATE(",
              "                    MAX('olap vw_fact_Movements'[DataRegistrazioneMagazzino]),",
              "                    'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _targetDate &&",
              "                    MONTH('olap vw_fact_Movements'[DataRegistrazioneMagazzino]) = _month &&",
              "                    YEAR('olap vw_fact_Movements'[DataRegistrazioneMagazzino]) = _year",
              "                )",
              "    )",
              "",
              "VAR _MonthlyStock =",
              "    ADDCOLUMNS(",
              "        _EndOfMonths,",
              "        \"StockQty\", ",
              "        VAR _EOM = [EOM]",
              "        RETURN",
              "        CALCULATE(",
              "            [_fx_StockQty],  ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _EOM, ",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "        )",
              "    )",
              "",
              "VAR _Average =",
              "    AVERAGEX(_MonthlyStock, [StockQty])",
              "",
              "RETURN",
              "    _Average"
            ],
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Stock Turn (qty) R12",
            "description": "Rapporto tra quantità negozi fisici 12 mesi rolling e media della quantità a stock 12 mesi rolling",
            "expression": " DIVIDE([Sales qty R12], [Average Stock Qty R12])",
            "formatString": "0.00",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Sell Out Rate (cost) R12",
            "description": "Rapporto tra costi negozi fisici 12 mesi rolling e la somma tra costi negozi fisici 12 mesi rolling e il valore di stock a costo alla data selezionata",
            "expression": " DIVIDE([Cog's R12], [Cog's R12]+[Closing Stock Cost R12])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Sell Out Rate (qty) R12",
            "description": "Rapporto tra quantità negozi fisici 12 mesi rolling e la somma tra quantità negozi fisici 12 mesi rolling e la quantità a stock alla data selezionata",
            "expression": " DIVIDE([Sales qty R12], [Sales qty R12]+[Closing Stock Qty R12])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Closing Stock Cost R12",
            "description": "Valore di stock a costo alla data selezionata",
            "expression": [
              " ",
              "",
              "VAR _maxDate = ",
              "    IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP], TODAY())",
              "",
              "VAR _ClosingStock =",
              "            CALCULATE(",
              "                [_fx_StockCost],",
              "                'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate,",
              "                USERELATIONSHIP(",
              "                    'olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],",
              "                    'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]",
              "                )",
              "\t)",
              "",
              "RETURN",
              "    SELECTCOLUMNS(",
              "        { _ClosingStock },",
              "        \"StockCost\", [Value]",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Closing Stock Qty R12",
            "description": "Valore della quantità a stock alla data selezionata",
            "expression": [
              " ",
              "",
              "VAR _maxDate = ",
              "    IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP], TODAY())",
              "",
              "VAR _ClosingStock =",
              "    CALCULATE(",
              "        [_fx_StockQty],",
              "        'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate,",
              "        USERELATIONSHIP(",
              "            'olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],",
              "            'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]",
              "        )",
              "    )",
              "",
              "RETURN",
              "    SELECTCOLUMNS(",
              "        { _ClosingStock },",
              "        \"StockQty\", [Value]",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Sales Margin R12",
            "description": "Margine delle vendite 12 mesi rolling",
            "expression": [
              " ",
              "",
              "VAR _maxDate = IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP] , TODAY())",
              "VAR _Result = ",
              "\tCALCULATE([_fx_VenditeNegoziFisici] - [_fx_CostoVendutoNegoziFisici], ",
              "\t\tFILTER('05 MOVEMENTS STORE ATTRIBUTES', '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _maxDate - 365 && '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= \t\t\t\t_maxDate )",
              "            \t)",
              "RETURN",
              "_Result"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Inc Manual Discount CP",
            "description": "Incidenza sconti manuali nel periodo selezionato",
            "expression": " DIVIDE([Total Manual Discount CP], [Net sales CP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Inc Manual Discount PP",
            "description": "Incidenza sconti manuali nel periodo precedente rispetto quello selezionato",
            "expression": " DIVIDE([Total Manual Discount PP], [Net sales PP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "△bp Inc Manual Discount CP vs PP",
            "description": "Differenza in punti percentuali in punti percentuali dell’incidenza degli sconti manuali tra il periodo selezionato e quello precedente",
            "expression": " ([Inc Manual Discount CP] - [Inc Manual Discount PP])*100",
            "formatString": "0.0",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "# Receipt CP with Manual Discount",
            "description": "Numero scontrini con sconti manuali nel periodo selezionato",
            "expression": " CALCULATE([# Receipt CP], '05 MOVEMENTS STORE ATTRIBUTES'[FlagManualDiscount]=1)",
            "formatString": "0",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Title Drill Store",
            "expression": " \"Store Detail: \" & SELECTEDVALUE('05 STORE ORGANIZATION'[StoreCodeDesc])",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Average Inc Manual Discount CP by Store",
            "description": "Incidenza media sconti manuali nel periodo selezionato per negozio",
            "expression": [
              " ",
              "CALCULATE([Inc Manual Discount CP],",
              "       \t\t ALL('05 STORE ORGANIZATION'[StoreCodeDesc])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Average Inc Manual Discount PP by Store",
            "description": "Incidenza media sconti manuali nel periodo precedente rispetto quello selezionato per negozio",
            "expression": [
              " ",
              "CALCULATE([Inc Manual Discount PP],",
              "       \t\t ALL('05 STORE ORGANIZATION'[StoreCodeDesc])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Average Inc Manual Discount CP by Date",
            "description": "Incidenza media sconti manuali nel periodo selezionato per data",
            "expression": [
              " ",
              "CALCULATE([Inc Manual Discount CP],",
              "       \t\t ALL('01 CALENDAR'[Date])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Average Inc Manual Discount CP by Cashier",
            "description": "Incidenza media sconti manuali nel periodo selezionato per cassiere",
            "expression": [
              " ",
              "CALCULATE([Inc Manual Discount CP],",
              "       \t\t ALL('02 CASHIER'[CashierCode])",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Color Inc Manual Discount over Avg by Store",
            "expression": [
              " ",
              "IF(",
              "    [Inc Manual Discount CP] > [Average Inc Manual Discount CP by Store] && [Inc Manual Discount PP] < [Average Inc Manual Discount PP by Store], ",
              "    \"#DD4871\", ",
              "    IF(",
              "        [Inc Manual Discount CP] > [Average Inc Manual Discount CP by Store] && [Inc Manual Discount PP] > [Average Inc Manual Discount PP by Store], ",
              "        \"#FFDF33\", ",
              "        \"#E6E6E6\"",
              "    )",
              ")"
            ],
            "displayFolder": "14 LOSS PREVENTION\\Color/Label/Others"
          },
          {
            "name": "Color Inc Manual Discount over Avg by Cashier",
            "expression": [
              " ",
              "IF(",
              "    [Inc Manual Discount CP] > [Average Inc Manual Discount CP by Cashier], ",
              "    \"#DD4871\", ",
              "    \"#E6E6E6\"",
              "    )"
            ],
            "displayFolder": "14 LOSS PREVENTION\\Color/Label/Others"
          },
          {
            "name": "Color Inc Manual Discount over Avg by Date",
            "expression": [
              " ",
              "IF(",
              "    [Inc Manual Discount CP] > [Average Inc Manual Discount CP by Date], ",
              "     \"#DD4871\",",
              "     \"#0D5A4C\"",
              "   ",
              "    )"
            ],
            "displayFolder": "14 LOSS PREVENTION\\Color/Label/Others"
          },
          {
            "name": "△bp Inc Manual Discont CP vs Avg",
            "description": "Differenza in punti percentuali tra incidenza sconti manuali nel perido selezionato e media sconti manuali",
            "expression": " ([Inc Manual Discount CP] - [Average Inc Manual Discount CP by Store])*100",
            "formatString": "0.0",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Movement cost CP",
            "description": "Costo di movimentazione della merce nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_StockCost], ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino]>= _minDate ,  'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]), USERELATIONSHIP('01 CALENDAR'[sk_Date],'olap vw_fact_Movements'[sk_Date]))"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty CP",
            "description": "Quanità movimentata nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_StockQty], ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino]>= _minDate ,  'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]), USERELATIONSHIP('01 CALENDAR'[sk_Date],'olap vw_fact_Movements'[sk_Date]))"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement cost PP",
            "description": "Costo di movimentazione della merce nel periodo precedente rispetto quello selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_StockCost], ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino]>= _minDate ,  'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty PP",
            "description": "Quanità movimentata nel periodo precedente rispetto quello selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_StockQty], ",
              "            'olap vw_fact_Movements'[DataRegistrazioneMagazzino]>= _minDate ,  'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△ Movement cost CP vs PP",
            "description": "Differenza movement cost tra il periodo selezionato e quello precedente",
            "expression": " [Movement cost CP] - [Movement cost PP]",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△% Movement cost CP vs PP",
            "description": "Variazione percentuale movement cost tra il periodo selezionato e quello precedente",
            "expression": " DIVIDE([△ Movement cost CP vs PP], [Movement cost PP])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△ Movement qty CP vs PP",
            "description": "Differenza movement qty tra il periodo selezionato e quello precedente",
            "expression": " [Movement qty CP] - [Movement qty PP]",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△% Movement qty CP vs PP",
            "description": "Variazione percentuale movement qty tra il periodo selezionato e quello precedente",
            "expression": " DIVIDE([△ Movement qty CP vs PP], [Movement qty PP])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty POS CP",
            "description": "Quanità movimentata negozi fisici + e-commerce nel periodo selezionato",
            "expression": " CALCULATE([Movement qty CP],  ('05 STORE ORGANIZATION'[ChannelCode] =\"DIR\" || '05 STORE ORGANIZATION'[ChannelCode] = \"ECOM\"), USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty POS PP",
            "description": "Quanità movimentata nel periodo precedente rispetto quello selezionato per canali DIR o ECOM",
            "expression": " CALCULATE([Movement qty PP],  ('05 STORE ORGANIZATION'[ChannelCode] =\"DIR\" || '05 STORE ORGANIZATION'[ChannelCode] = \"ECOM\"), USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△ Movement qty POS CP vs PP",
            "description": "Differenza quantità movimentata negozi fisici + e-commerce tra il periodo selezionato e quello precedente",
            "expression": " [Movement qty POS CP] - [Movement qty POS PP]",
