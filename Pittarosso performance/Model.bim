              "    VAR ___t = TOPN ( MaxFilters, ___f, StoreHistory[StoreValidTo] )",
              "    VAR ___d = CONCATENATEX ( ___t, StoreHistory[StoreValidTo], \", \" )",
              "    VAR ___x = \"StoreHistory[StoreValidTo] = \" & ___d & IF(___r > MaxFilters, \", ... [\" & ___r & \" items selected]\") & \" \" ",
              "    RETURN ___x & UNICHAR(13) & UNICHAR(10)",
              ")",
              "",
              "",
              ""
            ],
            "displayFolder": "99 Other"
          },
          {
            "name": "VAT Amount CP",
            "description": "Valore IVA periodo selezionato",
            "expression": [
              " ",
              "       ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE( SUM('05 MOVEMENTS STORE ATTRIBUTES'[VatAmount_CC]), ",
              "             '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]<= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])) ",
              ""
            ]
          },
          {
            "name": "#Selection_period_color",
