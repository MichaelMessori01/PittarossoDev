          {
            "name": "Rinforzo % Quantity",
            "description": "Percentuale quantità di rinforzo su totale quantità ordinata",
            "expression": " divide(CALCULATE([Ordered Quantity],'20 ORDERS DETAILS'[OrderTypeRemap]=\"Rinforzo\"),[Ordered Quantity])",
            "formatString": "0.0%;-0.0%;0.0%",
