          {
            "name": "# Orders e-com CP",
            "description": "Numero ordini e-com nel periodo selezionato",
            "expression": [
              " ",
              "     ",
              "/*VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "             )*/",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "           TREATAS(_ListaChiavi, 'olap vw_fact_RetailEcommerceSales'[sk_movement])                                                                                                                                            ",
              "          ),",
              "          CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate",
              "            )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS E-COMMERCE"
          },
          {
            "name": "# Orders e-com PP",
            "description": "Numero ordini e-com nel periodo precedente selezionato",
            "expression": [
              "      ",
              "/*VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC])",
              "             --)",
              ")*/",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            TREATAS(_ListaChiavi, 'olap vw_fact_RetailEcommerceSales'[sk_movement])                                                                                                                                          ",
              "          ),",
              "          CALCULATE([_fx_NrOrdiniECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate",
              "            )",
              ")",
              ""
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS E-COMMERCE"
