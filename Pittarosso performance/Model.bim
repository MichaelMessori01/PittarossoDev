      {
        "name": "07 AGEING",
        "columns": [
          {
            "name": "Ageing",
            "dataType": "string",
            "sourceColumn": "Ageing"
          },
          {
            "name": "Sk_DatePeriod",
            "dataType": "int64",
            "sourceColumn": "Sk_DatePeriod",
            "formatString": "0"
          },
          {
            "type": "calculated",
            "name": "AgeID",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              " IF ([Ageing] = \"NEW\", 1, ",
              "        IF ([Ageing] = \"NEXT\", 0, ",
              "            IF ([Ageing] = \"AGE -1\", 2,",
              "                IF ([Ageing] = \"AGE -2\", 3,",
              "                    IF ([Ageing] = \"AGE -3\", 4,",
              "                        IF ([Ageing] = \"AGE -4\", 5,",
              "                            IF ([Ageing] = \"AGE -5\", 6,",
              "                                IF ([Ageing] = \"AGE -6\", 7,",
              "                                    8))))))))"
            ]
          },
          {
            "type": "calculated",
            "name": "Ageing -7 & Older",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              " IF ([Ageing] = \"NEW\", \"NEW\", ",
              "        IF ([Ageing] = \"NEXT\", \"NEXT\", ",
              "            IF ([Ageing] = \"AGE -1\", \"AGE-1\",",
              "                IF ([Ageing] = \"AGE -2\", \"AGE-2\",",
              "                    IF ([Ageing] = \"AGE -3\", \"AGE-3\",",
              "                        IF ([Ageing] = \"AGE -4\", \"AGE-4\",",
              "                            IF ([Ageing] = \"AGE -5\", \"AGE-5\",",
              "                                IF ([Ageing] = \"AGE -6\", \"AGE-6\",",
              "                                    \"AGE-7 e Older\"))))))))"
            ],
            "sortByColumn": "AgeID"
          },
          {
            "name": "Sk_Movement",
            "dataType": "string",
            "sourceColumn": "Sk_Movement"
          },
