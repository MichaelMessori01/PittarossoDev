            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△% Movement qty POS CP vs PP",
            "description": "Variazione percentuale quantità movimentata negozi fisici + e-commerce tra il periodo selezionato e quello precedente",
            "expression": " DIVIDE([△ Movement qty POS CP vs PP], [Movement qty POS PP])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty WH CP",
            "description": "Quanità movimentata depositi nel periodo selezionato",
            "expression": " CALCULATE([Movement qty CP],  ('05 STORE ORGANIZATION'[ChannelCode] =\"WHS\"), USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty WH PP",
            "description": "Quanità movimentata depositi nel periodo precedente rispetto quello selezionato",
            "expression": " CALCULATE([Movement qty PP],  ('05 STORE ORGANIZATION'[ChannelCode] =\"WHS\"), USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△ Movement qty WH CP vs PP",
            "description": "Variazione assoluta quantità movimentata depositi tra il periodo selezionato e quello precedente",
            "expression": " [Movement qty WH CP] - [Movement qty WH PP]",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "△% Movement qty WH CP vs PP",
            "description": "Variazione percentuale quantità movimentata depositi tra il periodo selezionato e quello precedente per canal DIR o ECOM",
            "expression": " DIVIDE([△ Movement qty WH CP vs PP], [Movement qty WH PP])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty IN CP",
            "description": "Quanità movimentata in entrata nel periodo selezionato",
            "expression": [
              "",
              "CALCULATE(",
              "    [Movement qty CP],",
              "    'olap vw_fact_Movements'[sk_Store] <> 'olap vw_fact_Movements'[sk_DestinationStore],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"TRN\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement cost IN CP",
            "description": "Costo di movimentazione della merce in entrata nel periodo selezionato",
            "expression": [
              "",
              "CALCULATE(",
              "    [Movement cost CP],",
              "    'olap vw_fact_Movements'[sk_Store] <> 'olap vw_fact_Movements'[sk_DestinationStore],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"TRN\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty OUT CP",
            "description": "Quanità movimentata in uscita nel periodo selezionato",
            "expression": [
              "",
              "CALCULATE(",
              "    [Movement qty CP],",
              "     'olap vw_fact_Movements'[sk_Store] <> 'olap vw_fact_Movements'[sk_DestinationStore],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"VEN\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement cost OUT CP",
            "description": "Costo di movimentazione della merce in uscita nel periodo selezionato",
            "expression": [
              " ",
              "CALCULATE(",
              "    [Movement cost CP],",
              "     'olap vw_fact_Movements'[sk_Store] <> 'olap vw_fact_Movements'[sk_DestinationStore],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"VEN\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "# Stores",
            "description": "Numero distinto di stores aperti",
            "expression": " DISTINCTCOUNT('05 MOVEMENTS STORE ATTRIBUTES'[sk_Store]) + DISTINCTCOUNT('olap vw_fact_RetailEcommerceSales'[sk_Store])",
            "isHidden": true,
            "displayFolder": "01 SALES\\10 STORES"
          },
          {
            "name": "Movement qty From WHS to PDV CP",
            "description": "Quanità movimentata da depositi a punti vendita nel periodo selezionato",
            "expression": [
              "",
              "CALCULATE(",
              "    [Movement qty CP],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"VEN\",",
              "    '16 MOVEMENT CAUSAL'[MovementCausalCode]=\"301\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Movement qty From PDV to WHS CP",
            "description": "Quanità movimentata da punti vendita a depositi nel periodo selezionato",
            "expression": [
              "",
              "CALCULATE(",
              "    [Movement qty CP],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"VEN\",",
              "    '16 MOVEMENT CAUSAL'[MovementCausalCode]=\"303\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Stock qty inTransit CP",
            "expression": [
              "",
              "CALCULATE(",
              "    [Stock qty CP],",
              "    '14 WAREHOUSE'[WarehouseCode] = \"TRN\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\09 MOVEMENTS"
          },
          {
            "name": "Received Quantity",
            "description": "Quantità ricevuta",
            "expression": " CALCULATE(SUM('olap vw_fact_FactReceivedOrder'[Quantity]), 'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Gross Received",
            "description": "Prezzo fornitore senza sconti (e dazi e noli)",
            "expression": " CALCULATE(SUM('olap vw_fact_FactReceivedOrder'[AmountGrossDisc]),  'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value L4",
            "description": "Valore ricevuto L4 al lordo IVA",
            "expression": " CALCULATE(SUM('olap vw_fact_FactReceivedOrder'[Received L4]),  'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value LA",
            "description": "Valore ricevuto LA come somma di listino fornitore -sconti +dazi +noli",
            "expression": " CALCULATE(SUM('olap vw_fact_FactReceivedOrder'[Received LA]),  'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "# of Ref. Received",
            "description": "Numero referenze distinte ricevute",
            "expression": " CALCULATE(DISTINCTCOUNT('olap vw_fact_FactReceivedOrder'[ProductCode]),  'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value L4_noIva",
            "description": "Valore ricevuto L4 al netto IVA",
            "expression": " CALCULATE(sum('olap vw_fact_FactReceivedOrder'[Received L4])/1.22,  'olap vw_fact_FactReceivedOrder'[FlgPhysicalWarehouse]=1)",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value LA Left",
            "description": "Ordinato da ricevere rispetto valore ordinato LA in percentuale -indica la % ordinato da ricevere-",
            "expression": " IF(DIVIDE([Ordered Value LA]-[Received Value LA], [Ordered Value LA])>0,DIVIDE([Ordered Value LA]-[Received Value LA],[Ordered Value LA]), BLANK())",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value L4 Left",
            "description": "Ordinato da ricevere rispetto valore ordinato L4 in percentuale -indica la % ordinato da ricevere-",
            "expression": " IF(DIVIDE([Ordered Value L4]-[Received Value L4], [Ordered Value L4])>0,DIVIDE([Ordered Value L4]-[Received Value L4],[Ordered Value L4]), BLANK())",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Value LA vs Ordered %",
            "description": "Rapporto tra valore ricevuto LA e valore ordinato LA (poste con iva) -indica la % di ordinato ricevuto-",
            "expression": " DIVIDE([Received Value LA],[Ordered Value LA])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received LA Left KPI",
            "expression": " IF([Received Value LA Left] = 0 && [Ordered Value LA] > 0, \"⚠︎\", \"--\")",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received L4 Left KPI",
            "expression": " IF([Received Value L4 Left] = 0 && [Ordered Value L4] > 0, \"⚠︎\", \"--\")",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Quantity PrimoAss",
            "description": "Quantità ordinata di primo impianto",
            "expression": " CALCULATE([Received Quantity],'18 ORDERS'[OrderTypeRemap]=\"Primo Impianto\")",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Received Quantity Rinforzo",
            "description": "Quantità ricevuta di riassortimento",
            "expression": " CALCULATE([Received Quantity], '18 ORDERS'[OrderTypeRemap]=\"Rinforzo\")",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Rinforzo % Received Quantity",
            "description": "Percentuale quantità di rinforzo su totale quantità ricevuta",
            "expression": " DIVIDE([Received Quantity Rinforzo],[Received Quantity])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "# of Suppliers Receivement",
            "expression": " DISTINCTCOUNT('olap vw_fact_FactReceivedOrder'[SupplierCode])",
            "formatString": "#,0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% Received Value LA vs Ordered",
            "description": "Variazione percentuale tra valore ricevuto LA e ordinato LA",
            "expression": " DIVIDE([Received Value LA] - [Ordered Value LA], [Ordered Value LA])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% Received Quantity vs Ordered",
            "description": "Variazione percentuale tra quantità ordinata e ricevuta",
            "expression": " DIVIDE([Received Quantity] - [Ordered Quantity], [Ordered Quantity])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% #Ref Received vs Ordered",
            "description": "Variazione percentuale tra nr referenze ordinate e ricevute",
            "expression": " DIVIDE([# of Ref. Received] - [# of Ref. Ordered], [# of Ref. Ordered])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% Received Quantity PrimoAss vs Ordered",
            "description": "Variazione percentuale tra quantità di primo impianto ordinata e ricevuta",
            "expression": " DIVIDE([Received Quantity PrimoAss] - [Ordered Quantity PrimoAss], [Ordered Quantity PrimoAss])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% Received Quantity Rinforzo vs Ordered",
            "description": "Variazione percentuale tra quantità di rinforzo ricevuta e ordinata",
            "expression": " DIVIDE([Received Quantity Rinforzo] - [Ordered Quantity Rinforzo], [Ordered Quantity Rinforzo])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△% Received Value L4 vs Ordered",
            "description": "Variazione percentuale tra valore ricevuto L4 e ordinato L4",
            "expression": " DIVIDE([Received Value L4] - [Ordered Value L4], [Ordered Value L4])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "△bp Intake vs Ordered",
            "description": "Differenza in punti percentuali del margine rispetto l'ordinato",
            "expression": "([Intake %] - [Intake % Received])*100",
            "formatString": "0.0",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Intake EUR Received",
            "description": "Valore assoluto margine in EUR calcolato come differenza tra ricevuto L4 (no IVA) e ricevuto LA",
            "expression": "[Received Value L4_noIva]-[Received Value LA]",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "Intake % Received",
            "description": "Margine in percentuale ricevimenti",
            "expression": " divide([Intake EUR Received],[Received Value L4_noIva])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "15 RECEIVEMENTS"
          },
          {
            "name": "In-Take % Committed CP",
            "description": "Marginalità calcolata sulla merce disponibile nel periodo selezionato nel periodo selezionato",
            "expression": " DIVIDE((([Full sales without vat CP]+[Stock Value CP])-([Cog's CP]+[Stock cost CP])),([Full sales without vat CP]+[Stock Value CP]))",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "In-Take % Committed PP",
            "description": "Marginalità calcolata sulla merce disponibile nel periodo precedente rispetto quello selezionato",
            "expression": " DIVIDE((([Full sales without vat PP]+[Stock Value PP])-([Cog's PP]+[Stock cost PP])),([Full sales without vat PP]+[Stock Value PP]))",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "In-Take % Stock CP",
            "description": "Marginalità calcolata sullo stock alla data nel periodo selezionato",
            "expression": " DIVIDE([Stock Value CP] - [Stock cost CP], [Stock Value CP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "In-Take % Stock PP",
            "description": "Marginalità calcolata sullo stock alla data nel periodo precedente rispetto quello selezionato",
            "expression": " DIVIDE([Stock Value PP] - [Stock cost PP], [Stock Value PP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "In-Take % Stock Sold CP",
            "description": "Marginalità calcolata sul venduto nel periodo selezionato",
            "expression": " DIVIDE([Full sales without vat CP] - [Cog's CP], [Full sales without vat CP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "In-Take % Stock Sold PP",
            "description": "Marginalità calcolata sul venduto nel periodo precedente rispetto quello selezionato",
            "expression": " DIVIDE([Full sales without vat PP] - [Cog's PP], [Full sales without vat PP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\02 IN-TAKE MARGIN"
          },
          {
            "name": "Manual Row Discount CP",
            "description": "Sconto riga valore nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualRowDiscountUnitAmount_InValue]), ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Manual Row Discount % CP",
            "description": "Sconto riga percentuale nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualRowDiscountUnitAmount_InPercentage]), ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Manual Transaction Discount CP",
            "description": "Sconto transazione valore nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualHeaderDiscountUnitAmount_InValue]), ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Manual Transaction Discount % CP",
            "description": "Sconto transazione percentuale nel periodo selezionato",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualHeaderDiscountUnitAmount_InPercentage]), ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Manual Price Change CP",
            "description": "Sconto per modifica prezzo nel periodo selezionato",
            "expression": [
              "",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(ROUND(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualPriceChangeUnitAmount]), 2), ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Avg Manual Discount CP",
            "description": "Valore medio degli sconti manuali nel periodo selezionato",
            "expression": " DIVIDE([Total Manual Discount CP], [# Receipt stores CP])",
            "formatString": "0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Inc Transaction with Manual Discount CP",
            "description": "Incidenza del numero di transazioni con sconti manuali rispetto il totale delle transazioni nel periodo selezionato",
            "expression": " DIVIDE([# Receipt CP with Manual Discount], [# Receipt CP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Ordered Value LA + BDG",
            "description": "Misura utilizzata per vedere nel filtro collection solo quelle che hanno ordinato o bdg",
            "expression": " [Ordered Value LA] + [Ordered Value LA BDG]",
            "displayFolder": "11 ORDERS\\Color/Label/Others"
          },
          {
            "name": "# Stores CP",
            "description": "Numero distinto di stores aperti nel periodo selezionato",
            "expression": [
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "VAR Result =",
              "",
              "CALCULATE([# Stores], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              "",
              "VAR Result2 =",
              "",
              "CALCULATE(AVERAGEX(VALUES('01 CALENDAR'), [# Stores]),",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              "",
              "",
              "RETURN",
              "IF(",
              "    ISINSCOPE('01 CALENDAR'[Date]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialYear]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialSemester]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialQuarter]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialMonth]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialWeek]),",
              "    Result, ",
              "    Result2)"
            ],
            "formatString": "0",
            "displayFolder": "01 SALES\\10 STORES"
          },
          {
            "name": "# Stores PP",
            "description": "Numero distinto di stores aperti nel periodo precedente rispetto quello selezionato",
            "expression": [
              "",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "VAR Result =",
              "",
              "CALCULATE([# Stores], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))",
              "",
              "VAR Result2 =",
              "",
              "CALCULATE(AVERAGEX(VALUES('01 CALENDAR'), [# Stores]),",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))",
              "",
              "",
              "RETURN",
              "IF(",
              "    ISINSCOPE('01 CALENDAR'[Date]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialYear]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialSemester]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialQuarter]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialMonth]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialWeek]),",
              "    Result, ",
              "    Result2)"
            ],
            "formatString": "0",
            "displayFolder": "01 SALES\\10 STORES"
          },
          {
            "name": "Total Manual Discount CP",
            "description": "Sconti manuali nel periodo selezionato",
            "expression": [
              " ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualPriceChangeUnitAmount]) + SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualDiscountChangeUnitAmount]),",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0.00",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "Total Manual Discount PP",
            "description": "Sconti manuali nel periodo precedente rispetto quello selezionato",
            "expression": [
              " ",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE(SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualPriceChangeUnitAmount]) + SUM('05 MOVEMENTS STORE ATTRIBUTES'[ManualDiscountChangeUnitAmount]),",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))"
            ],
            "formatString": "#,0",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "# of Ref. with Discount",
            "description": "Indicazione per scontrino del numero di prodotti a cui è stato applicato uno sconto",
            "expression": " CALCULATE([Sales qty CP], '05 MOVEMENTS STORE ATTRIBUTES'[UnitDiscount_LC]<>0 )",
            "formatString": "0",
            "displayFolder": "14 LOSS PREVENTION"
          },
          {
            "name": "# Stores BDG",
            "description": "Numero distinto di stores a budget nel periodo selezionato",
            "expression": [
              " ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "VAR Result =",
              "",
              "CALCULATE(DISTINCTCOUNT('olap vw_fact_SalesBudget'[sk_Store]), 'olap vw_fact_SalesBudget'[BudgetAmountCC] <> 0,",
              "            'olap vw_fact_SalesBudget'[BudgetDate] >= _minDate , 'olap vw_fact_SalesBudget'[BudgetDate] <= _maxDate,",
              "             USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              "",
              "VAR Result2 =",
              "",
              "CALCULATE(AVERAGEX(VALUES('01 CALENDAR'), Result))",
              "",
              "RETURN",
              "IF(",
              "    ISINSCOPE('01 CALENDAR'[Date]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialYear]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialSemester]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialQuarter]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialMonth]) ||",
              "    ISINSCOPE('01 CALENDAR'[CommercialWeek]),",
              "    Result, ",
              "    Result2)"
            ],
            "formatString": "0",
            "displayFolder": "01 SALES\\10 STORES"
          },
          {
            "name": "Net Sales BDG Dept",
            "description": "Vendite netto sconti netto iva negozi fisici + e-commerce a budget (x dept) nel periodo selezionato",
            "expression": [
              " ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate = [End date CP]",
              "RETURN",
              "",
              "CALCULATE(",
              "            SUM('olap vw_fact_BudgetDepartment'[NetSalesBDG]),",
              "            'olap vw_fact_BudgetDepartment'[Date]>= _minDate ,'olap vw_fact_BudgetDepartment'[Date] <= _maxDate, ",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "            )"
            ],
            "formatString": "#,0",
            "displayFolder": "01 SALES\\02 NET SALES"
          },
          {
            "name": "Sales margin BDG Dept",
            "description": "Margine negozi fisici + e-commerce a budget (x dept) nel periodo selezionato",
            "expression": [
              " ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate = [End date CP]",
              "RETURN",
              "",
              "CALCULATE(",
              "            SUM('olap vw_fact_BudgetDepartment'[SalesMarginBDG]),",
              "            'olap vw_fact_BudgetDepartment'[Date]>= _minDate ,'olap vw_fact_BudgetDepartment'[Date] <= _maxDate, ",
              "            USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "            )"
            ],
            "formatString": "#,0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Sales Margin % BDG Dept",
            "description": "Margine % negozi fisici + e-commerce a budget (x dept) nel periodo selezionato",
            "expression": " DIVIDE([Sales margin BDG Dept],[Net Sales BDG Dept])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Δ Net sales CP vs BDG Dept",
            "description": "Variazione assoluta tra vendite e-com + negozi fisici (netto sconti e IVA) e BDG (x dept) nel periodo selezionato ",
            "expression": " [Net sales CP] - [Net Sales BDG Dept]",
            "formatString": "#,0",
            "displayFolder": "01 SALES\\02 NET SALES"
          },
          {
            "name": "Δ% Net sales CP vs BDG Dept",
            "description": "Variazione percentuale tra vendite negozi fisici (netto sconti e IVA) e BDG (x dept) nel periodo selezionato ",
            "expression": " DIVIDE([Δ Net sales CP vs BDG Dept], [Net Sales BDG Dept])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "01 SALES\\02 NET SALES"
          },
          {
            "name": "Δ Sales margin CP vs BDG Dept",
            "description": "Variazione assoluta tra margine e-com + negozi fisici nel periodo selezionato rispetto al BDG (x dept)",
            "expression": " [Sales margin CP] - [Sales margin BDG Dept]",
            "formatString": "#,0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Δbp Sales margin CP vs BDG Dept",
            "description": "Variazione in punti percentuali tra margine e-com + negozi fisici nel periodo selezionato rispetto al BDG (x dept)",
            "expression": " ([Sales margin % CP] - [Sales margin % BDG Dept])*100",
            "formatString": "0.0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Δ% Sales margin CP vs BDG Dept",
            "description": "Variazione percentuale tra margine e-com + negozi fisici nel periodo selezionato rispetto al BDG (x dept)",
            "expression": " DIVIDE([Δ Sales margin CP vs BDG Dept], [Sales margin BDG Dept])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Committed Cost CP",
            "description": "Somma di stock a costo e costo del venduto nel periodo selezionato",
            "expression": " [Cog's CP] + [Stock cost CP]",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\08 OTHER STOCK"
          },
          {
            "name": "Committed Cost PP",
            "description": "Somma di stock a costo e costo del venduto nel periodo precedente rispetto quello selezionato",
            "expression": " [Cog's PP] + [Stock cost PP]",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\08 OTHER STOCK"
          },
          {
            "name": "Δ full sales with vat CP vs PP",
            "description": "Variazione assoluta tra vendite e-com + negozi fisici lordo sconti lordo IVA nel periodo selezionato rispetto al periodo precedente",
            "expression": " [Full sales with vat CP] - [Full sales with vat PP]",
            "formatString": "#,0",
            "displayFolder": "01 SALES\\01  FULL SALES"
          },
          {
            "name": "Δ% full sales with vat CP vs PP",
            "description": "Variazione percentuale tra vendite e-com + negozi fisici lordo sconti lordo IVA nel periodo selezionato rispetto al periodo precedente",
            "expression": " DIVIDE([Δ full sales with vat CP vs PP], [Full sales with vat PP])",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "01 SALES\\01  FULL SALES"
          },
          {
            "name": "_fx_NrScontrini Test",
            "expression": [
              " CALCULATE(",
              "     COUNTROWS(",
              "        SUMMARIZE(",
              "            '05 MOVEMENTS STORE ATTRIBUTES', ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[Receipt_Part1], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[Receipt_Part2]",
              "        ) ",
              "        ",
              "    ),",
              "  KEEPFILTERS('05 STORE ORGANIZATION'[FormatLite]<>\"CORNER\"),",
              "    KEEPFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[FidelityCardActivationLine]<>\"1\" ),",
              "    KEEPFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[MovementType]<>\"Return\"))",
              " "
            ],
            "formatString": "0"
          },
          {
            "name": "_fx_NrOrdiniECommerce Test",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(",
              "        SUMMARIZE(  'olap vw_fact_RetailEcommerceSales',",
              "           'olap vw_fact_RetailEcommerceSales'[OrderNr]",
              "        )",
              "    ),",
              "    KEEPFILTERS(not ('olap vw_fact_RetailEcommerceSales'[DocumentType] in {\"Return\",\"Cancelled\"}))",
              ")",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "# Receipt stores CP Test",
            "expression": [
              " ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrScontrini Test], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "# Orders e-com CP Test",
            "expression": [
              " ",
              "     ",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrOrdiniECommerce Test], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "# Receipt CP Test",
            "expression": " [# Receipt stores CP Test] + [# Orders e-com CP Test]",
            "formatString": "0"
          },
          {
            "name": "# Receipt stores PP Test",
            "expression": [
              " ",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrScontrini Test], ",
              "             '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "# Orders e-com PP Test",
            "expression": [
              "      ",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_NrOrdiniECommerce Test], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))",
              ""
            ],
            "formatString": "0"
          },
          {
            "name": "# Receipt PP Test",
            "expression": " [# Receipt stores PP Test] + [# Orders e-com PP Test]",
            "formatString": "0"
          },
          {
            "name": "Δ # Receipt CP vs PP Test",
            "expression": " [# Receipt CP Test] - [# Receipt PP Test]",
            "formatString": "0"
          },
          {
            "name": "Δ% # Receipt CP vs PP Test",
            "expression": " DIVIDE([Δ # Receipt CP vs PP Test],[# Receipt PP Test])",
            "formatString": "0.0%;-0.0%;0.0%"
          },
          {
            "name": "Average spend CP Test",
            "expression": [
              "",
              " \tCALCULATE(DIVIDE([Net sales CP],[# Receipt CP Test]),",
              "\tKEEPFILTERS('03 MERCHANDISE ANALYSIS'[CategoryCode]<>\"98\"),",
              "\tKEEPFILTERS( '05 STORE ORGANIZATION'[FormatLite]<>\"CORNER\"))"
            ],
            "formatString": "0.0"
          },
          {
            "name": "Average spend PP Test",
            "expression": [
              "",
              " \tCALCULATE(DIVIDE([Net sales PP],[# Receipt PP Test]),",
              "\tKEEPFILTERS('03 MERCHANDISE ANALYSIS'[CategoryCode]<>\"98\"),",
              "\tKEEPFILTERS( '05 STORE ORGANIZATION'[FormatLite]<>\"CORNER\"))"
            ],
            "formatString": "0.0"
          }
        ]
      },
