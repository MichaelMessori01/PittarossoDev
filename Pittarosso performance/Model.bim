            "expression": " CALCULATE([Ordered Quantity],'20 ORDERS DETAILS'[OrderTypeRemap]=\"Riassortimento\")",
            "formatString": "0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Ordered Quantity Riass. seas-1",
            "description": "Quantità ordinata di riassortimento stagione passata",
            "expression": [
              " ",
              "var stag = left(SELECTEDVALUE('04 COLLECTION ANALYSIS'[CollectionCode]),2)",
              "var anno = RIGHT(SELECTEDVALUE('04 COLLECTION ANALYSIS'[CollectionCode]),2)-1",
              "var unify = CONCATENATE(stag,anno)",
              "",
              "return ",
              "CALCULATE([Ordered Quantity Riassort.], '04 COLLECTION ANALYSIS'[CollectionCode]=unify)"
            ],
            "formatString": "0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% Ordered Quantity Riass. vs seas-1",
            "description": "Variazione percentuale quantità riassortimento rispetto stagione precedente",
            "expression": " DIVIDE([Ordered Quantity Riassort.] - [Ordered Quantity Riass. seas-1], [Ordered Quantity Riass. seas-1])",
            "formatString": "0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "# Imballi Ass",
            "description": "Numero imballi pluritaglia",
            "expression": [
              "",
              "IF(",
              "    HASONEVALUE('13 SKU'[SizeCode]),",
              "    BLANK(),",
              "    VAR MaxOrigQty = ",
              "        SUMMARIZECOLUMNS(",
              "            '20 ORDERS DETAILS'[sk_PurchaseOrder],",
              "            '20 ORDERS DETAILS'[SizeCodeImballi],",
              "",
              "            FILTER(",
              "                '20 ORDERS DETAILS',",
              "                '20 ORDERS DETAILS'[FlagParcelBulk] = \"Collo\" && ",
              "                '20 ORDERS DETAILS'[SizeType] = \"Pluritaglia\"",
              "            ),",
              "            FILTER(",
              "             '18 ORDERS',",
              "             '18 ORDERS'[IsMasterNeutro] <> \"MN\"",
              "             ),",
              "            \"MaxOriginalQty\", MAX('20 ORDERS DETAILS'[OriginalQuantity])",
              "        )",
              "",
              "    VAR Result =",
              "        SUMX(MaxOrigQty, [MaxOriginalQty])",
              "",
              "    RETURN Result",
              ")"
            ],
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "# Imballi Mono",
            "description": "Numero imballi monotaglia",
            "expression": [
              " ",
              "",
              "IF(",
              "    HASONEVALUE('13 SKU'[SizeCode]),",
              "    BLANK(),",
              "    VAR MaxOrigQty = ",
              "        SUMMARIZECOLUMNS(",
              "            '20 ORDERS DETAILS'[sk_PurchaseOrder],",
              "            '20 ORDERS DETAILS'[SizeCodeImballi],",
              "",
              "            FILTER(",
              "                '20 ORDERS DETAILS',",
              "                '20 ORDERS DETAILS'[FlagParcelBulk] = \"Collo\" && ",
              "                '20 ORDERS DETAILS'[SizeType] = \"Monotaglia\"",
              "            ),",
              "            FILTER(",
              "            '18 ORDERS',",
              "            '18 ORDERS'[IsMasterNeutro] <> \"MN\"",
              "            ),",
              "            \"MaxOriginalQty\", MAX('20 ORDERS DETAILS'[OriginalQuantity])",
              "        )",
              "",
              "    VAR Result =",
              "        SUMX(MaxOrigQty, [MaxOriginalQty])",
              "",
              "    RETURN Result",
              ")"
            ],
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "# Imballi",
            "expression": " [# Imballi Ass] + [# Imballi Mono]",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Net sales R12",
            "description": "Vendite netto sconti netto iva negozi fisici 12 mesi rolling",
            "expression": [
              " ",
              "",
              "VAR _maxDate = IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP] , TODAY())",
              "VAR _Result = ",
              "\tCALCULATE([_fx_VenditeNegoziFisici], ",
              "\t\tFILTER('05 MOVEMENTS STORE ATTRIBUTES', '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= _maxDate - 365 && '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= \t\t\t\t_maxDate )",
              "            \t)",
              "RETURN",
              "_Result"
            ],
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "MQ R12",
            "description": "Metri quadri 12 mesi rolling",
            "expression": [
              " ",
              "-- Media ponderata per il numero di giorni che la zona è stata in una certa metratura",
              "",
              "VAR DataFinePeriodo = IF(ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), [End date CP] , TODAY())",
              "VAR DataInizioPeriodo = DataFinePeriodo - 365",
              "VAR TabellaFiltrata =",
              "    SUMMARIZECOLUMNS(",
              "\t\t'olap vw_fact_Zoning'[ZoneCode],",
              "\t\t'olap vw_fact_Zoning'[FromDate],",
              "\t\t'olap vw_fact_Zoning'[ToDate],",
              "\t\t'olap vw_fact_Zoning'[ZoneMq],",
              "\t\t",
              "        FILTER(",
              "            'olap vw_fact_Zoning',",
              "            'olap vw_fact_Zoning'[FromDate] <= DataFinePeriodo &&",
              "            'olap vw_fact_Zoning'[ToDate] >= DataInizioPeriodo",
              "        ),",
              "\t\t\"GiorniValidi\",",
              "            DATEDIFF(",
              "                IF(MAX('olap vw_fact_Zoning'[FromDate]) > DataInizioPeriodo, MAX('olap vw_fact_Zoning'[FromDate]), DataInizioPeriodo),",
              "                IF(MAX('olap vw_fact_Zoning'[ToDate]) < DataFinePeriodo, MAX('olap vw_fact_Zoning'[ToDate]), DataFinePeriodo),",
              "                DAY",
              "            ) + 1",
              "    )",
              "",
              "VAR MediaPonderata  =",
              "    DIVIDE(",
              "        SUMX(",
              "            TabellaFiltrata,",
              "            'olap vw_fact_Zoning'[ZoneMq] * [GiorniValidi]",
              "        ),",
              "        SUMX(TabellaFiltrata, [GiorniValidi])",
              "    )",
              "",
              "VAR SommaMediePonderate =",
              "    SUMX(",
              "        SUMMARIZE(",
              "            'olap vw_fact_Zoning',",
              "            'olap vw_fact_Zoning'[ZoneCode],",
              "            \"__MediaZone\",",
              "                VAR FiltriZona = ",
              "                    FILTER(",
              "                        TabellaFiltrata,",
              "                        'olap vw_fact_Zoning'[ZoneCode] = EARLIER('olap vw_fact_Zoning'[ZoneCode])",
              "                    )",
              "                RETURN DIVIDE(",
              "                    SUMX(FiltriZona, 'olap vw_fact_Zoning'[ZoneMq] * [GiorniValidi]),",
              "                    SUMX(FiltriZona, [GiorniValidi])",
              "                )",
              "        ),",
              "        [__MediaZone]",
              "    )",
              "",
              "RETURN",
              "IF(",
              "    ISINSCOPE('olap vw_fact_Zoning'[ZoneCode]),",
              "    MediaPonderata,",
              "    SommaMediePonderate",
              ")"
            ],
            "formatString": "#,0.0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "MQ",
            "description": "Metri quadri",
            "expression": " Sum('06 STORE ZOONING'[ZoneMq])",
            "formatString": "#,0.0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Sales Density R12",
            "description": "Rapporto tra Net sales negozi fisici 12 mesi rolling e metri quadri 12 mesi rolling",
            "expression": " DIVIDE([Net sales R12], [MQ R12])",
            "formatString": "#,0",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Inc Net sales R12",
            "description": "Rapporto tra Net sales negozi fisici 12 mesi rolling di una zona e Net Sales negozi fisici Totali",
            "expression": [
              " ",
              "\t\tDIVIDE(",
              "\t\t[Net sales R12],",
              "\t\t\tCALCULATE(",
              "\t\t\t[Net sales R12],",
              "\t\t\tALL('21 ZONE'[ZoneCode]),",
              "\t\t\tALL('21 ZONE'[Zone]),",
              "\t\t\tALL('21 ZONE'[GoodsType]),",
              "\t\t\tALL('21 ZONE'[GoodsTypeMacro])",
              "\t\t\t),",
              "\t\t0",
              "\t\t)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Inc MQ R12",
            "description": "Rapporto tra MQ 12 mesi rolling di una zona e MQ Totali",
            "expression": [
              " ",
              "\t\tDIVIDE(",
              "\t\t[MQ R12],",
              "\t\t\tCALCULATE(",
              "\t\t\t[MQ R12],",
              "\t\t\tALL('21 ZONE'[ZoneCode]),",
              "\t\t\tALL('21 ZONE'[Zone]),",
              "\t\t\tALL('21 ZONE'[GoodsType]),",
              "\t\t\tALL('21 ZONE'[GoodsTypeMacro])",
              "",
              "\t\t\t),",
              "\t\t0",
              "\t\t)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Space/Sales ratio R12",
            "description": "Sottrazione tra incidenza net sales R12 e incidenza MQ R12 moltiplicata per 100",
            "expression": " ([Inc Net sales R12] - [Inc MQ R12])*100\t",
            "formatString": "#,0.00",
            "displayFolder": "12 ZONING"
          },
          {
            "name": "Rolling 12M Period",
            "expression": [
              " ",
              "VAR SelectedDate = IF( ISFILTERED('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), MAX('olap vw_DynamicPeriodSelection_ToDatePC'[ToDatePC]), TODAY())",
              "VAR StartDate = EDATE(SelectedDate, -12)",
              "VAR StartDateFormatted = FORMAT(StartDate, \"dd/mm/yyyy\")",
              "VAR EndDateFormatted = FORMAT(SelectedDate, \"dd/mm/yyyy\")",
              "RETURN",
              "    \"Analysis period R12: \" & StartDateFormatted & \" - \" & EndDateFormatted",
              "   "
            ],
            "displayFolder": "12 ZONING\\Color/Label/Others"
          },
          {
            "name": "ASP Avrg Last 3 Week",
            "description": "Rapporto tra media vendite nette ultime 3 settimane esclusa la settima selezionata e media qty venduta ultime 3 settimane esclusa la categoria 98. Nel caso di una settimana aperta confronta i giorni settimanali chiusi",
            "expression": [
              "",
              "CALCULATE(",
              "DIVIDE([Net Sales Avrg Last 3 Weeks], [Sales qty Avrg Last 3 Weeks])",
              ",KEEPFILTERS('03 MERCHANDISE ANALYSIS'[CategoryCode]<>\"98\"))"
            ],
            "formatString": "0.0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Full sales with vat e-com Avrg Last 3 Weeks",
            "description": "Media delle vendite lordo sconti lordo iva e-commerce delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              " ",
              "      VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3Week =",
              "CALCULATE(",
              "    SUM('olap vw_fact_RetailEcommerceSales'[AmountGrossDiscGrossTax_CC]),",
              "    REMOVEFILTERS('olap vw_fact_RetailEcommerceSales'[OrderDate]),",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate]>= StartDate - 21 &&",
              "   'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR AvgPrice = DIVIDE(Last3Week, 3)",
              "",
              "RETURN AvgPrice"
            ],
            "isHidden": true,
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Full sales with vat stores Avrg Last 3 Weeks",
            "description": "Media delle vendite lordo sconti lordo iva negozi fisici delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              " ",
              "       ",
              " VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3Week =",
              "CALCULATE(",
              "    SUM('05 MOVEMENTS STORE ATTRIBUTES'[AmountGrossDiscGrossTax_CC]),",
              "    REMOVEFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]),",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR AvgPrice = DIVIDE(Last3Week, 3)",
              "",
              "RETURN AvgPrice"
            ],
            "isHidden": true,
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Net sales with vat e-com Avrg Last 3 Weeks",
            "description": "Media vendite netto sconti lordo iva e-commerce delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              " ",
              "      VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3Week =",
              "CALCULATE(",
              "    SUM('olap vw_fact_RetailEcommerceSales'[AmountNetDiscGrossTax_CC]),",
              "    REMOVEFILTERS('olap vw_fact_RetailEcommerceSales'[OrderDate]),",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] >= StartDate - 21 &&",
              "   'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR AvgPrice = DIVIDE(Last3Week, 3)",
              "",
              "RETURN AvgPrice"
            ],
            "isHidden": true,
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Net sales with vat stores Avrg Last 3 Weeks",
            "description": "Media vendite netto sconti lordo iva negozi fisici delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              " ",
              "       ",
              " VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3Week =",
              "CALCULATE(",
              "    SUM('05 MOVEMENTS STORE ATTRIBUTES'[AmountNetDiscGrossTax_CC]),",
              "    REMOVEFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]),",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR AvgPrice = DIVIDE(Last3Week, 3)",
              "",
              "RETURN AvgPrice"
            ],
            "isHidden": true,
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Markdown % Avrg Last 3 Weeks",
            "description": "(([Full sales with vat e-com Avrg Last 3 Weeks]+[Full sales with vat stores Avrg Last 3 Weeks])  -  ([Net sales with vat e-com Avrg Last 3 Weeks]+[Net sales with vat stores Avrg Last 3 Weeks]) / ([Full sales with vat e-com Avrg Last 3 Weeks]+[Full sales with vat stores Avrg Last 3 Weeks]))",
            "expression": " DIVIDE(([Full sales with vat e-com Avrg Last 3 Weeks]+[Full sales with vat stores Avrg Last 3 Weeks]) -  ([Net sales with vat e-com Avrg Last 3 Weeks]+[Net sales with vat stores Avrg Last 3 Weeks]), ([Full sales with vat e-com Avrg Last 3 Weeks]+[Full sales with vat stores Avrg Last 3 Weeks]))",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Net Sales vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra Net Sales CP e Net sales avrg last 3 weeks",
            "expression": [
              "",
              "DIVIDE([Net sales CP] - [Net Sales Avrg Last 3 Weeks], [Net Sales Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales qty vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra sales qty CP e sales qty avrg last 3 weeks",
            "expression": [
              "",
              "DIVIDE([Sales qty CP] - [Sales qty Avrg Last 3 Weeks], [Sales qty Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Markdown vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra tot. sconti periodo selezionato e media tot. sconti ultime 3 settimane",
            "expression": [
              "",
              "DIVIDE([Markdown value CP] - [Markdown Avrg Last 3 Weeks], [Markdown Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Markdown % vs Rolling Avrg Baseline Mobile",
            "description": "Differenza in punti percentuali tra tot. sconti periodo selezionato e media tot. sconti ultime 3 settimane",
            "expression": "([Markdown % CP] - [Markdown % Avrg Last 3 Weeks])*100",
            "formatString": "0.0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Retail Price vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra retail price CP e retail price avrg last 3 weeks",
            "expression": [
              "",
              "DIVIDE([Retail price CP]- [Retail price Avrg Last 3 Weeks], [Retail price Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "ASP vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra ASP periodo corrente e media ASP ultime 3 settimane",
            "expression": [
              "",
              "DIVIDE([ASP CP] - [ASP Avrg Last 3 Week], [ASP Avrg Last 3 Week])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales margin vs Rolling Avrg Baseline Mobile",
            "description": "Variazione percentuale tra sales margin CP e sales margin avrg last 3 weeks",
            "expression": [
              "",
              "DIVIDE([Sales margin CP] - [Sales margin Avrg Last 3 Weeks], [Sales margin Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales margin % vs Rolling Avrg Baseline Mobile",
            "description": "Variazione in punti percentuali tra sales margin % CP e sales margin % avrg last 3 weeks",
            "expression": "([Sales margin % CP] - [Sales margin % Avrg Last 3 Weeks])*100",
            "formatString": "0.0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Net Sales Avrg Last 3 Weeks",
            "description": "Media delle net sales delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              "",
              "",
              "VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR SalesLast3WeekStores =",
              "CALCULATE(",
              "    [_fx_VenditeNegoziFisici],",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR SalesLast3WeeksEcommerce =",
              "CALCULATE(",
              "    [_fx_VenditeECommerce],",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] >= StartDate - 21 &&",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "",
              "VAR AvgSales = DIVIDE(SalesLast3WeekStores+SalesLast3WeeksEcommerce, 3)",
              "",
              "RETURN AvgSales"
            ],
            "formatString": "#,0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales qty Avrg Last 3 Weeks",
            "description": "Media delle sales qty delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              "",
              "",
              "VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3WeekStores =",
              "CALCULATE(",
              "    [_fx_QuantitàNegoziFisici],",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR Last3WeeksEcommerce =",
              "CALCULATE(",
              "    [_fx_QuantitàEcommerce],",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] >= StartDate - 21 &&",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "",
              "VAR AvgQty = DIVIDE(Last3WeekStores+Last3WeeksEcommerce, 3)",
              "",
              "RETURN AvgQty"
            ],
            "formatString": "#,0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Markdown Avrg Last 3 Weeks",
            "description": "Media tot. sconti ultime 3 settimane",
            "expression": [
              "",
              "",
              "VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY()-1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3WeekStores =",
              "CALCULATE(",
              "    [_fx_DiscountNegoziFisici],",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "  ",
              "VAR Last3WeeksEcommerce =",
              "CALCULATE(",
              "    [_fx_DiscountEcommerce],",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] >= StartDate - 21 &&",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "",
              "VAR AvgMarkdown = DIVIDE(Last3WeekStores+Last3WeeksEcommerce, 3)",
              "",
              "RETURN AvgMarkdown"
            ],
            "formatString": "#,0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Retail price Avrg Last 3 Weeks",
            "description": "Rapporto tra ASP avrg last 3 weeks e (1-Markdown % avrg last 3 weeks)",
            "expression": [
              "",
              "",
              "divide([ASP Avrg Last 3 Week],1-[Markdown % Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales margin Avrg Last 3 Weeks",
            "description": "Media sales margin delle ultime 3 settimane esclusa la settima selezionata. Nel caso di una settimana aperta confronta i giorni settimanali chiusi.",
            "expression": [
              " ",
              "",
              "VAR EndDate = IF([End date CP] < TODAY(), [End date CP], TODAY() - 1)",
              "VAR StartDate = [Start date CP]",
              "VAR CurrentWeekDayNumber = WEEKDAY(EndDate, 2)",
              "",
              "",
              "VAR Last3WeekStores =",
              "",
              "CALCULATE(",
              "    ([_fx_VenditeNegoziFisici]-[_fx_CostoVendutoNegoziFisici]),",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] >= StartDate - 21 &&",
              "    '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] < StartDate &&",
              "    WEEKDAY('05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "",
              "VAR Last3WeekEcom =",
              "",
              "CALCULATE(",
              "    ([_fx_VenditeECommerce]-[_fx_CostoVendutoECommerce]),",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate]>= StartDate - 21 &&",
              "    'olap vw_fact_RetailEcommerceSales'[OrderDate] < StartDate &&",
              "    WEEKDAY('olap vw_fact_RetailEcommerceSales'[OrderDate], 2) <= CurrentWeekDayNumber,",
              "    USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "    )",
              "",
              "VAR AvgMargin= DIVIDE(Last3WeekStores+Last3WeekEcom, 3)",
              "",
              "RETURN AvgMargin"
            ],
            "formatString": "#,0",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Sales margin % Avrg Last 3 Weeks",
            "description": "Rapporto tra sales margin avrg last 3 weeks e net sales avrg last 3 weeks",
            "expression": [
              " ",
              "",
              "DIVIDE([Sales margin Avrg Last 3 Weeks], [Net Sales Avrg Last 3 Weeks])"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "13 Rolling 3 Weeks"
          },
          {
            "name": "Ref. Period Last 3 Weeks",
            "expression": [
              " ",
              "IF([End date CP] < TODAY(), [Start date CP]-21 & \" - \" & FORMAT([Start date CP]-21, \"ddd\") & \"     \" & [Start date CP]-1 & \" - \" & FORMAT([Start date CP]-1, \"ddd\"), [Start date CP]-21 & \" - \" & FORMAT([Start date CP]-21, \"ddd\") & \"     \" & [Start date CP]-1 & \" - \" & FORMAT([Start date CP]-1, \"ddd\") & UNICHAR(10) & \"*includes data only up to \" & FORMAT(TODAY()-1, \"dddd\", \"EN\"))"
            ],
            "displayFolder": "13 Rolling 3 Weeks\\Label"
          },
          {
            "name": "Selected Week",
            "expression": " IF([End date CP] < TODAY(), [StartDate CP] & \"     \" & [EndDate CP], [StartDate CP] & \"     \" & TODAY()-1 & \" - \" & FORMAT(TODAY()-1, \"ddd\"))",
            "displayFolder": "13 Rolling 3 Weeks\\Label"
          },
          {
            "name": "Mix sales qty (product) CP",
            "description": "Mix sales qty % merceologico secondo la gerarchia di appartenenza per il periodo selezionato (subcatt-->cat-->rep-->dip)",
            "expression": [
              "",
              "var MacroDepart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) ",
              "var VenditeMacroDepart = CALCULATE([Sales qty CP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[MacroDepartment] = MacroDepart))",
              "var VenditeTotali = CALCULATE([Sales qty CP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "var Depart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ",
              "var VenditeDepart = CALCULATE([Sales qty CP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc] = Depart))",
              "",
              "RETURN ",
              "SWITCH(",
              "    TRUE(),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Sales qty CP], VenditeTotali),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Sales qty CP], VenditeMacroDepart),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                    DIVIDE([Sales qty CP], VenditeDepart)",
              "       )"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "01 SALES\\07 MIX SALES PRODUCT"
          },
          {
            "name": "Mix sales qty (product) PP",
            "description": "Mix sales qty % merceologico secondo la gerarchia di appartenenza per il periodo precedente rispetto a quello selezionato (subcatt-->cat-->rep-->dip)",
            "expression": [
              "",
              "var MacroDepart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) ",
              "var VenditeMacroDepart = CALCULATE([Sales qty PP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[MacroDepartment] = MacroDepart))",
              "var VenditeTotali = CALCULATE([Sales qty PP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "var Depart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ",
              "var VenditeDepart = CALCULATE([Sales qty PP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc] = Depart))",
              "",
              "RETURN ",
              "SWITCH(",
              "    TRUE(),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Sales qty PP], VenditeTotali),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Sales qty PP], VenditeMacroDepart),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                    DIVIDE([Sales qty PP], VenditeDepart)",
              "       )"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "01 SALES\\07 MIX SALES PRODUCT"
          },
          {
            "name": "Committed Value CP",
            "description": "Somma di quantità di stock e vendite lordo sconti negozi fisici + e-commerce nel periodo selezionato al netto IVA",
            "expression": " DIVIDE([Stock Value CP] + [Full sales with vat CP], 1.22)",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\08 OTHER STOCK"
          },
          {
            "name": "Committed Value PP",
            "description": "Somma di quantità di stock e vendite lordo sconti negozi fisici + e-commerce nel periodo precedente rispetto quello selezionato al netto IVA",
            "expression": " DIVIDE([Stock Value PP] + [Full sales with vat PP], 1.22)",
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\08 OTHER STOCK"
          },
          {
