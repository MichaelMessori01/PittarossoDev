          },
          {
            "name": "ManualDiscountChangeUnitAmount",
            "dataType": "double",
            "description": "Somma il valore degli sconti di riga, riga%, transazione, transazione %",
            "isHidden": true,
            "sourceColumn": "ManualDiscountChangeUnitAmount"
          },
          {
            "name": "FlagManualRowDiscount",
            "dataType": "int64",
