              "/*VAR SelectedDepartments = VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "VAR RequiredDepartments =",
              "    DATATABLE(\"MacroDepartment\", STRING, {{\"Footwear\"}, {\"No Footwear\"}, {\"Others\"}})",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "",
              "VAR OnlyThreeSelected = CountSelected = 3 && MatchCount = 3",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])   ",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || OnlyThreeSelected,",
              "         ([Sales margin % CP] - [Sales Margin % BDG]) * 100,",
              "        BLANK()",
              "    )",
              ")",
              "*/",
              "",
              "VAR SelectedDepartments =",
              "    VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "",
              "VAR RequiredDepartments =",
              "    DATATABLE(",
              "        \"MacroDepartment\", STRING,",
              "        {",
              "            {\"Footwear\"},",
              "            {\"No Footwear\"},",
              "            {\"Others\"},",
              "            {\"Concession\"}",
              "        }",
              "    )",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "VAR AllFourSelected = CountSelected = 4 && MatchCount = 4",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])",
              "",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || AllFourSelected,",
              "         ([Sales margin % CP] - [Sales Margin % BDG]) * 100,",
              "        BLANK()",
              "    )",
              ")",
              ""
            ],
            "formatString": "0.0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Δbp STR Qty CP vs PP",
            "description": "Variazione in punti percentuali tra indice di rotazione della merce calcolato rispetto alle quantità disponibili nel periodo selezionato rispetto al periodo precedente",
            "expression": " ([STR Qty CP]-[STR Qty PP])*100",
            "formatString": "0.0",
            "displayFolder": "07 STOCK\\05 SELL TROUGH"
          },
          {
            "name": "Sales margin BDG",
