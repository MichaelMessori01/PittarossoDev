            "expression": [
              "",
              "var Supplier = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[SupplierCode_Desc]) ",
              "var VenditeSupplier = CALCULATE([Net sales CP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[SupplierCode_Desc] = Supplier))",
              "var VenditeTotali = CALCULATE([Net sales CP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "",
              "",
