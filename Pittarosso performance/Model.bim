          },
          {
            "type": "calculated",
            "name": "StoreCodeDesc",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": "'05 STORE ORGANIZATION'[StoreCode]&\"-\"&'05 STORE ORGANIZATION'[Store]"
          },
          {
            "name": "LFLPerimeter",
            "dataType": "string",
            "sourceColumn": "LFLPerimeter"
          },
          {
            "type": "calculated",
            "name": "FormatLite",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              " IF('05 STORE ORGANIZATION'[Format] = \"Corner\", ",
              "                   \"CORNER\", ",
              "                    IF('05 STORE ORGANIZATION'[Format] = \"Shop in shop\",   ",
              "                            \"SHOP IN SHOP\",  ",
              "                            IF('05 STORE ORGANIZATION'[Format] = \"E-commerce\",  ",
              "                                    \"E-COMMERCE\", ",
              "                                    \"OTHER\")))"
            ]
          },
          {
            "type": "calculated",
            "name": "PerimeterType",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              " IF('05 STORE ORGANIZATION'[LFLPerimeter] = \"LFL\",   ",
              "           \"LFL\",  ",
              "            IF(LEFT('05 STORE ORGANIZATION'[LFLPerimeter], 2) = \"CH\",",
              "                          \"CH\",",
              "                          IF(LEFT('05 STORE ORGANIZATION'[LFLPerimeter], 2) = \"NA\",",
              "                                        \"NA\",",
              "                                         '05 STORE ORGANIZATION'[LFLPerimeter]",
              "                            )",
              "              )",
              "    )"
            ]
