              "             'olap vw_fact_SalesBudget'[BudgetDate]>= _minDate ,'olap vw_fact_SalesBudget'[BudgetDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC]))",
              ""
            ],
            "formatString": "#,0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Sales margin stores BDG",
