          },
          {
            "name": "DumpFilters",
            "expression": [
              "VAR MaxFilters = 10",
              "RETURN",
              "IF ( ",
              "    ISFILTERED ( '01 CALENDAR'[CommercialDatePY] ), ",
              "    VAR ___f = FILTERS ( '01 CALENDAR'[CommercialDatePY] ) ",
              "    VAR ___r = COUNTROWS ( ___f ) ",
              "    VAR ___t = TOPN ( MaxFilters, ___f, '01 CALENDAR'[CommercialDatePY] )",
              "    VAR ___d = CONCATENATEX ( ___t, '01 CALENDAR'[CommercialDatePY], \", \" )",
              "    VAR ___x = \"'01 CALENDAR'[CommercialDatePY] = \" & ___d & IF(___r > MaxFilters, \", ... [\" & ___r & \" items selected]\") & \" \" ",
