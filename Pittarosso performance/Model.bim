          },
          {
            "name": "Ordered Quantity Filter",
            "description": "Totale quantità ordinata indipendentemente dalla stagione",
            "expression": " CALCULATE([Ordered Quantity],all('04 COLLECTION ANALYSIS'[Collection]),all('04 COLLECTION ANALYSIS'[CollectionCode]))",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
