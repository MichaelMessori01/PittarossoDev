              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "VAR AllFourSelected = CountSelected = 4 && MatchCount = 4",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])",
              "",
