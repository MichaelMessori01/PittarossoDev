          },
          {
            "name": "Sales Margin % e-com BDG",
            "description": "Margine % e-commerce a budget nel periodo selezionato",
            "expression": " DIVIDE([Sales margin e-com BDG],[Net sales e-com BDG])",
            "formatString": "0",
            "displayFolder": "00 DETAILS E-COMMERCE"
          },
          {
            "name": "Net sales e-com PP",
            "description": "Vendite netto sconti netto iva e-commerce nel periodo precedente rispetto a quello selezionato",
            "expression": [
              " ",
              "/*",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_VenditeECommerce], ",
              "             'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate]<= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC])",
              "             )*/",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_VenditeECommerce], ",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "            TREATAS(_ListaChiavi, 'olap vw_fact_RetailEcommerceSales'[sk_movement])                                                                                                                                             ",
              "          ),",
              "          CALCULATE([_fx_VenditeECommerce], ",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate",
              "            )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS E-COMMERCE"
          },
          {
            "name": "Δ Net sales e-com CP vs BDG",
            "description": "Variazione assoluta tra vendite e-com (netto sconti e IVA) e BDG nel periodo selezionato ",
            "expression": " [Net sales e-com CP] - [Net sales e-com BDG]",
            "formatString": "#,0",
            "displayFolder": "00 DETAILS E-COMMERCE"
          },
          {
            "name": "Mix sales (product) CP",
            "description": "Mix sales % merceologico secondo la gerarchia di appartenenza per il periodo selezionato (subcatt-->cat-->rep-->dip) - per funzionare il dep. dev'essere espresso nella modsalità codice+descrizione",
            "expression": [
              "",
              "var MacroDepart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) ",
              "var VenditeMacroDepart = CALCULATE([Net sales CP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[MacroDepartment] = MacroDepart))",
              "var VenditeTotali = CALCULATE([Net sales CP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "var Depart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ",
              "var VenditeDepart = CALCULATE([Net sales CP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc] = Depart))",
              "",
              "RETURN ",
              "SWITCH(",
              "    TRUE(),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Net sales CP], VenditeTotali),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Net sales CP], VenditeMacroDepart),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                    DIVIDE([Net sales CP], VenditeDepart)",
              "       )"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "01 SALES\\07 MIX SALES PRODUCT"
          },
          {
            "name": "Mix sales (product) PP",
            "description": "Mix sales % merceologico secondo la gerarchia di appartenenza per il periodo precedente rispetto a quello selezionato (subcatt-->cat-->rep-->dip) - per funzionare il dep. dev'essere espresso nella modsalità codice+descrizione",
            "expression": [
              "",
              "var MacroDepart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) ",
              "var VenditeMacroDepart = CALCULATE([Net sales PP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[MacroDepartment] = MacroDepart))",
              "var VenditeTotali = CALCULATE([Net sales PP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "var Depart = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ",
              "var VenditeDepart = CALCULATE([Net sales PP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc] = Depart))",
              "",
              "RETURN ",
              "SWITCH(",
              "    TRUE(),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[MacroDepartment]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Net sales PP], VenditeTotali),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                   DIVIDE([Net sales PP], VenditeMacroDepart),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Product])), ",
              "                    DIVIDE([Net sales PP], VenditeDepart)",
              "       )"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "01 SALES\\07 MIX SALES PRODUCT"
          },
          {
            "name": "Sales% on total",
            "expression": [
              " ",
              "var VenditeTotali = CALCULATE([Net sales CP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "RETURN",
              "    DIVIDE([Net sales CP], VenditeTotali)"
            ],
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "01 SALES\\09 MIX SALES ON TOTAL"
