          {
            "name": "Test_2",
            "expression": [
              " ",
              "",
              "VAR _minDate = [Start Date CP Previous Week -4]",
              "VAR _maxDate =  [End Date CP Previous Week]",
              "RETURN",
              "_maxDate&_minDate"
            ]
          },
          {
            "name": "Ordered Quantity",
            "description": "Quantità ordinata (vengono esclusi master neutri)",
            "expression": " CALCULATE(sum('20 ORDERS DETAILS'[Quantity]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Gross Ordered",
            "description": "Prezzo fornitore senza sconti (e dazi e noli)",
            "expression": " CALCULATE(sum('20 ORDERS DETAILS'[AmountGrossDisc]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "intake BDG",
            "description": "Valore assoluto margine di budget in EUR",
            "expression": " [Ordered Value L4 BDG_noIva]-[Ordered Value LA BDG]",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Ordered Value L4",
            "description": "Valore ordinato L4 al lordo IVA (vengono esclusi i master neutri)",
            "expression": "CALCULATE( sum('20 ORDERS DETAILS'[Ordered L4]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Intake EUR",
            "description": "Valore assoluto margine in EUR",
            "expression": "[Ordered Value L4_noIva]-[Ordered Value LA]",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Intake %",
            "description": "Margine in percentuale ordinato",
            "expression": " divide([Intake EUR],[Ordered Value L4_noIva])",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Intake % BDG",
            "description": "Margine di budget in percentuale",
            "expression": " divide([intake BDG],[Ordered Value L4 BDG_noIva])",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Ordered Quantity PrimoAss",
            "description": "Quantità ordinata di primo impanto",
            "expression": " CALCULATE([Ordered Quantity],'18 ORDERS'[OrderTypeRemap]=\"Primo Impianto\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Ordered Quantity Rinforzo",
            "description": "Quantità ordinata di rinforzo",
            "expression": " CALCULATE([Ordered Quantity], '18 ORDERS'[OrderTypeRemap]=\"Rinforzo\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Average order price L4",
            "description": "Prezzo medio listino di vendita",
            "expression": " DIVIDE([Ordered Value L4],[Ordered Quantity])",
            "formatString": "#,0.0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "# of Ref. Ordered",
            "description": "Numero referenze distinte acquistate",
            "expression": " CALCULATE(DISTINCTCOUNT('20 ORDERS DETAILS'[ProductCode]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Remaining ordered BDG",
            "description": "Differenza tra budget a valore LA e valore ordinato LA -indica il bdg disponibile-",
            "expression": " [Ordered Value LA BDG]-[Ordered Value LA]",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Remaining ordered BDG %",
            "description": "Variazione percentuale tra budget a valore LA e valore ordinato LA -indica la % di budget disponibile-",
            "expression": " divide([Remaining ordered BDG],[Ordered Value LA BDG])",
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Dazio",
            "description": "Dazi",
            "expression": "CALCULATE(sum('20 ORDERS DETAILS'[Duties_Amount]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Nolo",
            "description": "Noli",
            "expression": "CALCULATE(sum('20 ORDERS DETAILS'[Charter_Amount]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "# of Suppliers",
            "description": "Numero fornitori",
            "expression": " CALCULATE(DISTINCTCOUNT('20 ORDERS DETAILS'[SupplierCode]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△bp Intake vs BDG",
            "description": "Differenza in punti percentuali tra margine e margine di BDG",
            "expression": [
              " ",
              "if(or(ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]),ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc])),",
              "\tBLANK(), ",
              "([Intake %]-[Intake % BDG])*100)"
            ],
            "formatString": "0.0",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Ordered Value L4 BDG",
            "description": "Budget a valore L4 (con iva)",
            "expression": " sum('olap vw_fact_PurchaseBudget'[Value])*1.22",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Ordered Value LA BDG",
            "description": "Budget a valore LA",
            "expression": " sum('olap vw_fact_PurchaseBudget'[Cost])",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\02 BDG"
          },
          {
            "name": "Ordered Value LA",
            "description": "Valore ordinato LA come somma di listino fornitore -sconti +dazi + noli (vengono esclusi i master neutri)",
            "expression": " CALCULATE(sum('20 ORDERS DETAILS'[AmountNetDisc_LA]), '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Average order price LA",
            "description": "Prezzo medio listino di acquisto",
            "expression": " DIVIDE([Ordered Value LA],[Ordered Quantity])",
            "formatString": "#,0.0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "Ordered Value L4 without vat",
            "description": "Valore ordinato L4 al netto IVA (vengono esclusi i master neutri)",
            "expression": " CALCULATE(sum('20 ORDERS DETAILS'[Ordered L4])/1.22, '18 ORDERS'[IsMasterNeutro] <> \"MN\")",
            "formatString": "#,0",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% Ordered Quantity vs seas-1",
            "description": "Variazione percentuale quantità ordinata rispetto stagione precedente",
            "expression": " DIVIDE([Ordered Quantity] - [Ordered Quantity seas-1], [Ordered Quantity seas-1])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% Ordered vs seas-1",
            "description": "Variazione percentuale valore ordinato LA rispetto stagione precedente",
            "expression": " DIVIDE([Ordered Value LA] - [Ordered Value LA seas-1], [Ordered Value LA seas-1])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% # of Suppliers vs seas-1",
            "description": "Variazione percentuale numero fornitori rispetto stagione precedente",
            "expression": " DIVIDE([# of Suppliers] - [# of Suppliers seas-1], [# of Suppliers seas-1])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% # of Ref. Ordered vs seas-1",
            "description": "Variazione percentuale numero referenze ordinate rispetto stagione precedente",
            "expression": " DIVIDE([# of Ref. Ordered] - [# of Ref. Ordered seas-1], [# of Ref. Ordered seas-1])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% Avg price LA vs seas-1",
            "description": "Variazione percentuale prezzo medio LA rispetto stagione precedente",
            "expression": " DIVIDE([Average order price LA] - [Avg order price LA seas-1], [Avg order price LA seas-1])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "11 ORDERS\\01 ACT"
          },
          {
            "name": "△% Avg price L4 vs seas-1",
            "description": "Variazione percentuale prezzo medio L4 rispetto stagione precedente",
