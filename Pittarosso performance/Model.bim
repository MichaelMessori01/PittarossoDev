        "measures": [
          {
            "name": "_fx_VenditeNegoziFisici",
            "expression": "SUM('05 MOVEMENTS STORE ATTRIBUTES'[AmountNetDiscNetTax_CC])",
            "formatString": "\"#,0.00\"",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_VenditeECommerce",
            "expression": " SUM( 'olap vw_fact_RetailEcommerceSales'[AmountNetDiscNetTax_CC])",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_Budget",
            "expression": [
              "",
              "/*VAR SelectedDepartments = VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "VAR RequiredDepartments =",
              "    DATATABLE(\"MacroDepartment\", STRING, {{\"Footwear\"}, {\"No Footwear\"}, {\"Others\"}})",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "",
              "VAR OnlyThreeSelected = CountSelected = 3 && MatchCount = 3",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])   ",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || OnlyThreeSelected,",
              "        CALCULATE(",
              "            SUM('olap vw_fact_SalesBudget'[BudgetAmountCC]),",
              "            'olap vw_fact_SalesBudget'[BudgetType] = \"Vendite Negozi\"",
              "        ),",
              "        BLANK()",
              "    )",
              ")*/",
              "",
              "VAR SelectedDepartments =",
              "    VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "",
              "VAR RequiredDepartments =",
              "    DATATABLE(",
              "        \"MacroDepartment\", STRING,",
              "        {",
              "            {\"Footwear\"},",
              "            {\"No Footwear\"},",
              "            {\"Others\"},",
              "            {\"Concession\"}",
              "        }",
              "    )",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "VAR AllFourSelected = CountSelected = 4 && MatchCount = 4",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])",
              "",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || AllFourSelected,",
              "        CALCULATE(",
              "            SUM('olap vw_fact_SalesBudget'[BudgetAmountCC]),",
              "            'olap vw_fact_SalesBudget'[BudgetType] = \"Vendite Negozi\"",
              "        ),",
              "        BLANK()",
              "    )",
              ")"
            ],
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_CostoVendutoNegoziFisici",
            "expression": [
              " SUM('05 MOVEMENTS STORE ATTRIBUTES'[CostofGoodSold])",
              ""
            ],
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_CostoVendutoECommerce",
            "expression": [
              " /*SUMX('olap vw_fact_RetailEcommerceSales','olap vw_fact_RetailEcommerceSales'[CostOfGoodSold]*'olap vw_fact_RetailEcommerceSales'[Qty])",
              " mm commentata per provare nuova versione senza sumX che ha previsto di modificare la definizione della colonna CostOfGoodSold da unitaria a totale",
              " */",
              " SUM('olap vw_fact_RetailEcommerceSales'[TotalCostOfGoodSoldLC])"
            ],
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_NrScontrini",
            "expression": [
              " CALCULATE(",
              "    COUNTROWS(",
              "        SUMMARIZE(",
              "            '05 MOVEMENTS STORE ATTRIBUTES',",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[Receipt_Part1],",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[Receipt_Part2]",
              "        )",
              "    ),",
              "    KEEPFILTERS('05 STORE ORGANIZATION'[FormatLite]<>\"CORNER\"),",
              "    KEEPFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[FidelityCardActivationLine]<>\"1\" ),",
              "    KEEPFILTERS('05 MOVEMENTS STORE ATTRIBUTES'[MovementType]<>\"Return\"))"
            ],
            "formatString": "#,0",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_Ingressi",
            "expression": "if(or(ISFILTERED('07 AGEING'), ISFILTERED('03 MERCHANDISE ANALYSIS')), BLANK(), SUM('olap vw_fact_PeopleCounter'[PeopleIn]))",
            "formatString": "#,0",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_BudgetNegoziFisici",
            "expression": " CALCULATE([_fx_Budget], KEEPFILTERS( '05 STORE ORGANIZATION'[ChannelCode] <>\"ECOM\"))",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_BudgetEcommerce",
            "expression": " CALCULATE([_fx_Budget], KEEPFILTERS( '05 STORE ORGANIZATION'[ChannelCode] =\"ECOM\"))",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_NrOrdiniECommerce",
            "expression": [
              "",
              " CALCULATE(",
              "    COUNTROWS(",
              "        SUMMARIZE(  'olap vw_fact_RetailEcommerceSales',",
              "           'olap vw_fact_RetailEcommerceSales'[OrderNr]",
              "        )",
              "    ),",
              "    KEEPFILTERS(not ('olap vw_fact_RetailEcommerceSales'[DocumentType] in {\"Return\",\"Cancelled\"}))",
              ")",
              "",
              "",
              "",
              "",
              "",
              "",
              "/*",
              "calculate(\t DISTINCTCOUNT('olap vw_fact_RetailEcommerceSales'[OrderNr]),",
              "\t KEEPFILTERS(not ('olap vw_fact_RetailEcommerceSales'[DocumentType] in {\"Return\",\"Cancelled\"}))",
              ")*/"
            ],
            "formatString": "#,0",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "Color_buttons_todate",
            "expression": " if(SELECTEDVALUE('olap vw_DynamicPeriodSelection_Selector'[Period]) in {\"MTD\",\"YTD\",\"STD\",\"WTD\"}, \"#46736B\",\"#FFFFFF\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_buttons_dinamica",
            "expression": " if(SELECTEDVALUE('olap vw_DynamicPeriodSelection_Selector'[PeriodObject]) in {\"Year\",\"Month\",\"Semester\",\"Day\",\"Week\"}, \"#46736B\",\"#FFFFFF\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_buttons_P1vsP2",
            "expression": " if((not (SELECTEDVALUE('olap vw_DynamicPeriodSelection_Selector'[PeriodObject]) in {\"Year\",\"Month\",\"Semester\",\"Day\",\"Week\"} || SELECTEDVALUE('olap vw_DynamicPeriodSelection_Selector'[Period]) in {\"MTD\",\"YTD\",\"STD\",\"WTD\"})) && HASONEFILTER('olap vw_DynamicPeriodSelection_FromDatePC'[FromDatePC_text]), \"#46736B\",\"#FFFFFF\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "_fx_QuantitàNegoziFisici",
            "expression": " SUM('05 MOVEMENTS STORE ATTRIBUTES'[Quantity])",
            "formatString": "#,0",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_QuantitàEcommerce",
            "expression": " SUM('olap vw_fact_RetailEcommerceSales'[Qty])",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_DiscountNegoziFisici",
            "expression": " SUM('05 MOVEMENTS STORE ATTRIBUTES'[DiscountAmount])",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_DiscountEcommerce",
            "expression": [
              " /*SUMX('olap vw_fact_RetailEcommerceSales', ",
              "        ('olap vw_fact_RetailEcommerceSales'[UnitDiscountAmountLC] * 'olap vw_fact_RetailEcommerceSales'[ExchangeRateLCtoCC]) * 'olap vw_fact_RetailEcommerceSales'[Qty])",
              "        ",
              "   c'era già la colonna calcolata DiscountAmount e quindi non serve fare sumx ma semplice somma della colonna calcolata",
              "*/",
              "SUM('olap vw_fact_RetailEcommerceSales'[DiscountAmount])"
            ],
            "formatString": "0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "Color_Delta Vendite Cy vs PY",
            "expression": [
              " if([Δ% Net sales CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
              ""
            ],
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta Marginalità CY vs PY",
            "expression": [
              " if([Δ Sales margin CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
              ""
            ],
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta Marginalità% CY vs PY",
            "expression": [
              " if([Δ% sales margin CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
              ""
            ],
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta% Vendite vs Budget CY",
            "expression": [
              " if([Δ% Net sales CP vs BDG]<0,\"#E7433F\",\"#50AC6A\")",
              ""
            ],
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta% Discount CY vs PY",
            "expression": " if([Δ% markdown value CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta% Totale Quantità CY vs PY",
            "expression": " if([Δ% sales qty CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "Color_Delta% Vendite CY vs PY",
            "expression": " if([Δ% Net sales CP vs PP]<0,\"#E7433F\",\"#50AC6A\")",
            "displayFolder": "Color/Label/Others"
          },
          {
            "name": "E-Commerce AmountNetDiscNetTax_LC",
            "description": "Valore e-com netto sconti e IVA",
            "expression": " SUM( 'olap vw_fact_RetailEcommerceSales'[AmountNetDiscNetTax_LC])",
            "formatString": "#,0.00",
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_StockQty",
            "expression": " SUM('olap vw_fact_Movements'[Qty])",
            "formatString": "0",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_VenditeNegoziFisici_LordoSconti_NettoIVA",
            "expression": " SUMX('05 MOVEMENTS STORE ATTRIBUTES',divide( '05 MOVEMENTS STORE ATTRIBUTES'[AmountGrossDiscGrossTax_CC],(1+('05 MOVEMENTS STORE ATTRIBUTES'[VatRate]/100))))",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "E-Commerce AmountGrossDiscNetTax_LC",
            "description": "Valore e-com lordo sconti netto IVA",
            "expression": [
              " /*SUMX('olap vw_fact_RetailEcommerceSales', ",
              "                       'olap vw_fact_RetailEcommerceSales'[GrossDiscNetVatUnitAmountLC] * 'olap vw_fact_RetailEcommerceSales'[NetQty])",
              "                       ",
              "*/",
              "",
              "SUM('olap vw_fact_RetailEcommerceSales'[GrossDiscNetVatAmountLC])"
            ],
            "formatString": "#,0.00",
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_VenditeECommerce_LordoSconti_NettoIVA",
            "expression": " SUM('olap vw_fact_RetailEcommerceSales'[AmountGrossDiscNetTax_CC])",
            "formatString": "#,0.00",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_Budget_Marginalità",
            "expression": [
              "",
              "/*",
              "VAR SelectedDepartments = VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "VAR RequiredDepartments =",
              "    DATATABLE(\"MacroDepartment\", STRING, {{\"Footwear\"}, {\"No Footwear\"}, {\"Others\"}})",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "",
              "VAR OnlyThreeSelected = CountSelected = 3 && MatchCount = 3",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])   ",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || OnlyThreeSelected,",
              "        CALCULATE(",
              "            SUM('olap vw_fact_SalesBudget'[BudgetAmountCC]),",
              "            'olap vw_fact_SalesBudget'[BudgetType] = \"Marginalità Negozi\"",
              "        ),",
              "        BLANK()",
              "    )",
              ")*/",
              "",
              "",
              "VAR SelectedDepartments =",
              "    VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "",
              "VAR RequiredDepartments =",
              "    DATATABLE(",
              "        \"MacroDepartment\", STRING,",
              "        {",
              "            {\"Footwear\"},",
              "            {\"No Footwear\"},",
              "            {\"Others\"},",
              "            {\"Concession\"}",
              "        }",
              "    )",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "VAR AllFourSelected = CountSelected = 4 && MatchCount = 4",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])",
              "",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || AllFourSelected,",
              "          CALCULATE(",
              "            SUM('olap vw_fact_SalesBudget'[BudgetAmountCC]),",
              "            'olap vw_fact_SalesBudget'[BudgetType] = \"Marginalità Negozi\"",
              "",
              "        ),",
              "        BLANK()",
              "    )",
              ")"
            ],
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_BudgetMarginalitàEcommerce",
            "expression": " CALCULATE([_fx_Budget_Marginalità], KEEPFILTERS( '05 STORE ORGANIZATION'[ChannelCode] =\"ECOM\"))",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "_fx_BudgetMarginalitàNegoziFisici",
            "expression": " CALCULATE([_fx_Budget_Marginalità], KEEPFILTERS( '05 STORE ORGANIZATION'[ChannelCode] <>\"ECOM\"))",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "Δ Sales margin CP vs BDG",
            "description": "Variazione assoluta tra margine e-com + negozi fisici nel periodo selezionato rispetto al BDG",
            "expression": [
              "",
              "VAR SelectedDepartments = VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "VAR RequiredDepartments =",
              "    DATATABLE(\"MacroDepartment\", STRING, {{\"Footwear\"}, {\"No Footwear\"}, {\"Others\"}})",
              "",
              "VAR MatchCount =",
              "    COUNTROWS(",
              "        INTERSECT(",
              "            SelectedDepartments,",
              "            RequiredDepartments",
              "        )",
              "    )",
              "VAR CountSelected = COUNTROWS(SelectedDepartments)",
              "",
              "VAR OnlyThreeSelected = CountSelected = 3 && MatchCount = 3",
              "VAR NoSelection = NOT ISFILTERED('03 MERCHANDISE ANALYSIS')",
              "",
              "VAR AnyOtherFilter =",
              "    ISFILTERED('07 AGEING') ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[DepartmentCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[CategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[SubCategoryCode_Desc]) ||",
              "    ISFILTERED('03 MERCHANDISE ANALYSIS'[ProductCode_Desc])   ",
              "RETURN",
              "IF (",
              "    AnyOtherFilter,",
              "    BLANK(),",
              "    IF (",
              "        NoSelection || OnlyThreeSelected,",
              "        [Sales margin CP] - [Sales Margin BDG],",
              "        BLANK()",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "Sales Margin % BDG",
            "description": "Margine % negozi fisici + e-commerce a budget nel periodo selezionato",
            "expression": " DIVIDE([Sales margin BDG],[Net sales BDG])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "04 SALES MARGIN\\01 SALES MARGIN"
          },
          {
            "name": "STR Qty CP",
            "description": "Indice di rotazione della merce calcolato rispetto alle quantità disponibili nel periodo selezionato; l'indicatore comprende lo stock a magazzino",
            "expression": " DIVIDE([Sales qty CP], [Sales qty CP] + [Stock qty CP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "07 STOCK\\05 SELL TROUGH"
          },
          {
            "name": "STR Qty PP",
            "description": "Indice di rotazione della merce calcolato rispetto alle quantità disponibili nel periodo precedente rispetto a quello selezionato; l'indicatore comprende lo stock a magazzino",
            "expression": " DIVIDE([Sales qty PP], [Sales qty PP] + [Stock qty PP])",
            "formatString": "0.0%;-0.0%;0.0%",
            "displayFolder": "07 STOCK\\05 SELL TROUGH"
          },
          {
            "name": "Net sales stores CP",
            "description": "Vendite netto sconti netto iva negozi fisici nel periodo selezionato",
            "expression": [
              " ",
              "/*",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "            )*/",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            TREATAS(_ListaChiavi, '05 MOVEMENTS STORE ATTRIBUTES'[sk_movement])                                                                                                                                            ",
              "          ),",
              "          CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate",
              "            )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS STORES"
          },
          {
            "name": "Net sales e-com CP",
            "description": "Vendite netto sconti netto iva e-commerce nel periodo selezionato",
            "expression": [
              " ",
              "/*",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "RETURN",
              "",
              "CALCULATE([_fx_VenditeECommerce], ",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC])",
              "            )*/",
              "",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDate =  [End date CP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_VenditeECommerce], ",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate,",
              "           TREATAS(_ListaChiavi, 'olap vw_fact_RetailEcommerceSales'[sk_movement])                                                                                                                                      ",
              "          ),",
              "          CALCULATE([_fx_VenditeECommerce], ",
              "            'olap vw_fact_RetailEcommerceSales'[OrderDate] >= _minDate ,'olap vw_fact_RetailEcommerceSales'[OrderDate] <= _maxDate                                                                                                                                           ",
              "          )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS E-COMMERCE"
          },
          {
            "name": "Net sales CP",
            "description": "Vendite netto sconti netto iva negozi fisici + e-commerce nel periodo selezionato",
            "expression": " [Net sales stores CP] + [Net sales e-com CP]",
            "formatString": "#,0",
