          },
          {
            "name": "Stock Value CP",
            "description": "Stock a valore di vendita netto iva (calcolato sull'ultimo L4 presente nel periodo) totale (negozi + e-commerce + depositi) nel periodo selezionato",
            "expression": [
              " ",
              "VAR _maxDate = [End date CP]",
              "VAR _minDate = [Start date CP]",
              "VAR _maxDateYear =",
              "    YEAR ( [End date CP] )",
              "VAR _maxfiltered =",
              "    if(ISFILTERED('01 CALENDAR'[DayName]), CALCULATE ( MAX ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear && '01 CALENDAR'[Date]<=_maxDate),CALCULATE ( MAX ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ))",
              "VAR tab2 = { ( _maxfiltered ), ( _maxDate ) }",
              "VAR min3 =",
              "    MINX ( tab2, [Value] )",
              "VAR _maxDate2 =",
              "    IF ( ISFILTERED ( '01 CALENDAR' ), min3, _maxDate )",
              "VAR tab = { ( _maxDate2 ), ( _maxDate ) }",
              "VAR min2 =",
              "    MINX ( tab, [Value] )",
              "VAR test =",
              "    IF (",
              "        CALCULATE ( MIN ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ) < _maxDate,",
              "        CALCULATE ( MIN ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ),",
              "        _maxfiltered",
              "    )",
              "VAR test2 =",
              "    IF ( ISFILTERED ( '01 CALENDAR'[Date] ), MAX ( '01 CALENDAR'[Date] ), _maxDate )",
              "VAR test3 =",
              "    IF ( ISFILTERED ( '01 CALENDAR'[Date] ), MAX ( '01 CALENDAR'[Date] ), _minDate )",
              "VAR test4 =",
              "    IF ( ISBLANK ( MAX ( '01 CALENDAR'[Date] ) ), BLANK (), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [_fx_StockValue],",
              "        'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate2",
              "            && test <= _maxDate",
              "            && _maxDate2 >= _minDate",
              "            && _maxDate2 <= min2",
              "            && test2 <= _maxDate",
              "            && test3 >= _minDate",
              "            && test4 = 1,",
              "        USERELATIONSHIP ( 'olap vw_dim_PeriodDateAssociation'[sk_ToDatePC], 'DynamicPeriodSelection_Bridge_ToDate_CP'[sk_ToDatePC] )",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\03 STOCK VALUE"
          },
          {
            "name": "_fx_StockValue",
            "expression": " SUM('olap vw_fact_Movements'[L4Cost])",
            "isHidden": true,
            "displayFolder": "fx_base"
          },
          {
            "name": "Stock Value PP",
            "description": "Stock a valore di vendita netto iva (calcolato sull'ultimo L4 presente nel periodo) totale (negozi + e-commerce + depositi) nel periodo precedente rispetto a quello selezionato",
            "expression": [
              " ",
              "VAR _maxDate = [End date PP]",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDateYear =",
              "    YEAR ( [End date CP] )-1",
              "VAR _maxfiltered =",
              "    if(ISFILTERED('01 CALENDAR'[DayName]), CALCULATE ( MAX ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear && '01 CALENDAR'[Date]<=_maxDate),CALCULATE ( MAX ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ))",
              "VAR tab2 = { ( _maxfiltered ), ( _maxDate ) }",
              "VAR min3 =",
              "    MINX ( tab2, [Value] )",
              "VAR _maxDate2 =",
              "    IF ( ISFILTERED ( '01 CALENDAR' ), min3, _maxDate )",
              "VAR tab = { ( _maxDate2 ), ( _maxDate ) }",
              "VAR min2 =",
              "    MINX ( tab, [Value] )",
              "VAR test =",
              "    IF (",
              "        CALCULATE ( MIN ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ) < _maxDate,",
              "        CALCULATE ( MIN ( '01 CALENDAR'[Date] ), '01 CALENDAR'[Year] = _maxDateYear ),",
              "        _maxfiltered",
              "    )",
              "VAR test2 =",
              "    IF ( ISFILTERED ( '01 CALENDAR'[Date] ), MAX ( '01 CALENDAR'[Date] ), _maxDate )",
              "VAR test3 =",
              "    IF ( ISFILTERED ( '01 CALENDAR'[Date] ), MAX ( '01 CALENDAR'[Date] ), _minDate )",
              "VAR test4 =",
              "    IF ( ISBLANK ( MAX ( '01 CALENDAR'[Date] ) ), BLANK (), 1 )",
              "RETURN",
              "    CALCULATE (",
              "        [_fx_StockValue],",
              "        'olap vw_fact_Movements'[DataRegistrazioneMagazzino] <= _maxDate2",
              "            && test <= _maxDate",
              "            && _maxDate2 >= _minDate",
              "            && _maxDate2 <= min2",
              "            && test2 <= _maxDate",
              "            && test3 >= _minDate",
              "            && test4 = 1,",
              "        USERELATIONSHIP ( 'olap vw_dim_PeriodDateAssociation'[sk_ToDatePC], 'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC] )",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "07 STOCK\\03 STOCK VALUE"
          },
