            "type": "calculated",
            "name": "FlagPriceChange",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "description": "Assume valore 1 se è stato applicato uno sconto per modifica prezzo",
            "expression": " IF('05 MOVEMENTS STORE ATTRIBUTES'[ManualPriceChangeUnitAmount] <> 0, 1, 0)",
            "summarizeBy": "none"
          },
          {
            "type": "calculated",
            "name": "FlagManualDiscount",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "description": "Assume valore 1 se è stato applicato uno sconto di riga, transazione o modifica prezzo",
            "expression": " IF( '05 MOVEMENTS STORE ATTRIBUTES'[FlagManualHeaderDiscount]=1 || '05 MOVEMENTS STORE ATTRIBUTES'[FlagManualRowDiscount]=1 || '05 MOVEMENTS STORE ATTRIBUTES'[FlagPriceChange]=1, 1, 0)",
            "summarizeBy": "none"
          },
