          {
            "name": "Sales Margin % stores BDG",
            "description": "Margine % negozi fisici a budget nel periodo selezionato",
            "expression": " DIVIDE([Sales margin stores BDG],[Net sales stores BDG])",
            "formatString": "0.0%;-0.0%;0.0%",
