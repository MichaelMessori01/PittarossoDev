            "description": "Variazione percentuale tra retail price price committed nel periodo selezionato rispetto al periodo precedente",
            "expression": " DIVIDE([Δ Retail price committed CP vs PP], [Retail price committed PP])",
            "formatString": "0.0%;-0.0%;0.0%",
