          {
            "name": "Net sales stores PP",
            "description": "Vendite netto sconti netto iva negozi fisici nel periodo precedente rispetto a quello selezionato",
            "expression": [
              " ",
              "/*",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "RETURN",
              "",
              "CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate , '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate, USERELATIONSHIP('olap vw_dim_PeriodDateAssociation'[sk_ToDatePC],'DynamicPeriodSelection_Bridge_ToDate_PP'[sk_ToDatePC]))",
              "*/",
              "",
              "VAR _minDate = [Start date PP]",
              "VAR _maxDate =  [End date PP]",
              "VAR _Company = VALUES('08 COMPANY'[CompanyCode])",
              "VAR _ListaChiavi = ",
              "CALCULATETABLE( ",
              "DISTINCT('07 AGEING'[sk_movement]), ",
              "KEEPFILTERS('07 AGEING'[CommercialSemesterStartDate] <= _maxDate), KEEPFILTERS('07 AGEING'[CommercialSemesterEndDate] >= _maxDate),",
              "TREATAS(_Company, '07 AGEING'[CompanyCode])",
              ")",
              "",
              "RETURN",
              "",
              "IF(ISCROSSFILTERED('07 AGEING'),",
              "          CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate,",
              "            TREATAS(_ListaChiavi, '05 MOVEMENTS STORE ATTRIBUTES'[sk_movement])                                                                                                                                            ",
              "          ),",
              "          CALCULATE([_fx_VenditeNegoziFisici], ",
              "            '05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate]>= _minDate ,'05 MOVEMENTS STORE ATTRIBUTES'[ReceiptDate] <= _maxDate",
              "            )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "00 DETAILS STORES"
          },
          {
            "name": "Cog's stores PP",
            "description": "Costo del venduto negozi fisici nel periodo precedente rispetto quello selezionato",
