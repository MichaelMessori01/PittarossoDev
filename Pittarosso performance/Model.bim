            "summarizeBy": "none"
          },
          {
            "type": "calculated",
            "name": "AmountNetDisc_LA",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": "'20 ORDERS DETAILS'[PriceListOrder_LA_LC]*'20 ORDERS DETAILS'[Quantity]",
            "summarizeBy": "none"
          },
          {
            "type": "calculated",
            "name": "Fascia Prezzo",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "if('20 ORDERS DETAILS'[PriceListe_L4]<10,\"<9,99\",",
              "\tif('20 ORDERS DETAILS'[PriceListe_L4]<20,\"10-19,99 €\",",
              "\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<30,\"20-29,99 €\",",
              "\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<40,\"30-39,99 €\",",
              "\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<50,\"40-59,99 €\",",
              "\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<60,\"60-69,99 €\",",
              "\t\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<70,\"70-89,99 €\",",
              "\t\t\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<80,\"80-99,99 €\",\">100\"))))))))"
            ],
            "sortByColumn": "Fascia Prezzo Sort"
          },
          {
            "type": "calculated",
            "name": "Fascia Prezzo Sort",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              "if('20 ORDERS DETAILS'[PriceListe_L4]<10,1,",
              "\tif('20 ORDERS DETAILS'[PriceListe_L4]<20,2,",
              "\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<30,3,",
              "\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<40,4,",
              "\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<50,5,",
              "\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<60,6,",
              "\t\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<70,7,",
              "\t\t\t\t\t\t\tif('20 ORDERS DETAILS'[PriceListe_L4]<80,8,9))))))))"
            ]
          },
