          {
            "name": "Δ Net sales CP vs BDG",
            "description": "Variazione assoluta tra vendite e-com + negozi fisici (netto sconti e IVA) e BDG nel periodo selezionato ",
            "expression": [
              "",
              "/*VAR SelectedDepartments = VALUES('03 MERCHANDISE ANALYSIS'[MacroDepartment])",
              "VAR RequiredDepartments =",
