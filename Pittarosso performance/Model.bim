          },
          {
            "name": "Mix sales (supplier-brand) PP",
            "description": "Mix sales % merceologico secondo la gerarchia di appartenenza per il periodo precedente rispetto a quello selezionato (supplier-->brand)",
            "expression": [
              "",
              "var Supplier = SELECTEDVALUE('03 MERCHANDISE ANALYSIS'[SupplierCode_Desc]) ",
              "var VenditeSupplier = CALCULATE([Net sales PP], FILTER(ALLSELECTED('03 MERCHANDISE ANALYSIS'), '03 MERCHANDISE ANALYSIS'[SupplierCode_Desc] = Supplier))",
              "var VenditeTotali = CALCULATE([Net sales PP], ALLSELECTED('03 MERCHANDISE ANALYSIS'))",
              "",
              "",
              "RETURN ",
              "SWITCH(",
              "    TRUE(),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[SupplierCode_Desc]) && NOT(ISINSCOPE('03 MERCHANDISE ANALYSIS'[Brand])), ",
              "                   DIVIDE([Net sales PP], VenditeTotali),",
              "        ISINSCOPE('03 MERCHANDISE ANALYSIS'[Brand]), ",
              "                   DIVIDE([Net sales PP], VenditeSupplier)",
              "       )"
            ],
            "formatString": "#,0.0%;-#,0.0%;#,0.0%",
            "displayFolder": "01 SALES\\08 MIX SALES SUPPLIER"
          },
