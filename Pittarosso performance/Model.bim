          },
          {
            "type": "calculated",
            "name": "ManualPriceChangeUnitAmount",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": "( [UnitPriceGrossDiscGrossTax_LC] - [UnitPriceNetDiscGrossTax_LC]) - [ManualDiscountUnitAmount]",
            "summarizeBy": "none"
          },
          {
            "name": "sk_PriceRange_L4",
            "dataType": "int64",
